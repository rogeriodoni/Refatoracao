			.Height = 25
			.AutoSize = .F.
			.BackStyle = 0
			.BorderStyle = 0
			.ButtonCount = 2
			.Value = 1
			.Buttons(1).Caption = "Ativo"
			.Buttons(1).AutoSize = .T.
			.Buttons(2).Caption = "Inativo - Ap" + CHR(243) + "s :"
			.Buttons(2).AutoSize = .T.
			.Visible = .T.
		ENDWITH

		*-- 4. Código de Barras (Left=626, Top=155, Width=108, Height=21)
		loc_oPgDados.AddObject("txt_4c_CodigoBarras", "TextBox")
		WITH loc_oPgDados.txt_4c_CodigoBarras
			.Left = 626
			.Top = 155
			.Width = 108
			.Height = 21
			.InputMask = "99999999999999"
			.Value = ""
			.Visible = .T.
		ENDWITH

		*-- 5. Grupo (Left=113, Top=178, Width=31, Height=23)
		loc_oPgDados.AddObject("txt_4c_Grupo", "TextBox")
		WITH loc_oPgDados.txt_4c_Grupo
			.Left = 113
