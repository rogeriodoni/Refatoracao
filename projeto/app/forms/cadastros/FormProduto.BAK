		*-- 8. Fornecedor (Left=113, Top=274, Width=80, Height=23)
		loc_oPgDados.AddObject("txt_4c_Fornecedor", "TextBox")
		WITH loc_oPgDados.txt_4c_Fornecedor
			.Left = 113
			.Top = 274
			.Width = 80
			.Height = 23
			.MaxLength = 10
			.Value = ""
			.Visible = .T.
		ENDWITH

		*-- 9. Descrição Fornecedor (Left=194, Top=274, Width=318, Height=23)
		loc_oPgDados.AddObject("txt_4c_DescFornecedor", "TextBox")
		WITH loc_oPgDados.txt_4c_DescFornecedor
			.Left = 194
			.Top = 274
			.Width = 318
			.Height = 23
			.ReadOnly = .T.
			.BackColor = RGB(240, 240, 240)
			.Value = ""
			.Visible = .T.
		ENDWITH

		*-- 10. Obs. Pedidos (Left=626, Top=287, Width=220, Height=21)
		loc_oPgDados.AddObject("txt_4c_ObsPedidos", "TextBox")
		WITH loc_oPgDados.txt_4c_ObsPedidos
			.Left = 626
			.Top = 287
			.Width = 220
			.Height = 21
			.MaxLength = 30
			.Value = ""
