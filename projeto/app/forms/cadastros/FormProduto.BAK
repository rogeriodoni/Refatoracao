*=================================================================================
* FORMPRODUTO - CADASTRO DE PRODUTOS (FASE 1 - MVP)
*=================================================================================
* Descricao: Formulario para cadastro de produtos (migração SIGCDPRO)
* Autor: Claude Code
* Data: 2026-01-16
* Versao: 1.0 - Fase 1 (MVP - 15 campos básicos, sem pgframeDados aninhado)
*
* IMPORTANTE FASE 1:
* - 15 campos básicos dispostos diretamente na Page2 (sem PageFrame aninhado)
* - 2 lookups apenas (Grupo e Fornecedor)
* - Grid com 7 colunas (modo padrão, Tipo2 = .F.)
* - Layout simplificado é aceitável (foco em funcionalidade, não pixel-perfect)
* - Fases 2 e 3 adicionarão pgframeDados com 17 sub-páginas
*=================================================================================

DEFINE CLASS FormProduto AS FormBase

	*-- Propriedades visuais do formulário (CRÍTICAS - copiadas do FormCor)
	DataSession = 2
	Height = 600
	Width = 1000
	Caption = "Cadastro de Produtos"
	ShowWindow = 1      && REGRA: Usar 1 (não 2) para compatibilidade com modal
	WindowType = 1      && REGRA: Modal definido na classe
	AutoCenter = .T.

	*-- Propriedades do frmcadastro (SEM barra de título, SEM botões de janela)
	ControlBox = .F.    && Sem menu de controle
	Closable = .F.      && Sem botão fechar
	MaxButton = .F.     && Sem botão maximizar
	MinButton = .F.     && Sem botão minimizar
	TitleBar = 0        && Sem barra de título
	ClipControls = .F.  && Otimização de repintura
	Themes = .F.        && Sem temas do Windows (aparência clássica)
	BorderStyle = 2     && Borda fixa

	*-- Propriedades de negócio
	this_cTitulo = "Cadastro de Produtos"
	this_cTabela = "SigCdPro"
	this_cChavePrimaria = "cpros"

	*-- Controle de modo do formulário
	this_cModoAtual = "LISTA"         && LISTA, INCLUIR, ALTERAR, VISUALIZAR
	this_cCodigoAtual = ""            && Código do registro atual

	*-- Nomes de campos para descrição (lookup)
	this_cDescGrupo = ""
	this_cDescFornecedor = ""

	*===========================================================================
	* METODO: Init
	*===========================================================================
	PROCEDURE Init()
		LOCAL loc_lSucesso
		loc_lSucesso = .T.

		TRY
			*-- Criar Business Object
			THIS.this_oBusinessObject = CREATEOBJECT("ProdutoBO")

			*-- Construir interface (estrutura básica)
			THIS.ConstruirInterface()

			*-- Carregar lista inicial (pular se validando UI)
			IF TYPE("gb_4c_ValidandoUI") != "L" OR !gb_4c_ValidandoUI
				IF !THIS.CarregarLista()
					*-- Se falhar ao carregar, não impede abertura do form
				ENDIF
			ENDIF

			*-- Ativar Page1 (Lista)
			THIS.pgf_4c_Principal.ActivePage = 1
			THIS.this_cModoAtual = "LISTA"

		CATCH TO loc_oErro
			MESSAGEBOX("Erro no Init() do FormProduto:" + CHR(13) + ;
			           "Mensagem: " + loc_oErro.Message + CHR(13) + ;
			           "Linha: " + TRANSFORM(loc_oErro.LineNo) + CHR(13) + ;
			           "Procedure: " + loc_oErro.Procedure, 16, "Erro")
			loc_lSucesso = .F.
		ENDTRY

		RETURN loc_lSucesso
	ENDPROC

	*===========================================================================
	* METODO: ConstruirInterface
	*===========================================================================
	PROTECTED PROCEDURE ConstruirInterface()
		*-- Criar PageFrame principal
		THIS.AdicionarPageFrame()

		*-- Configurar Page1 (Lista)
		THIS.ConfigurarPage1()

		*-- Configurar Page2 (Dados)
		THIS.ConfigurarPage2()

		*-- CRÍTICO: Tornar controles visíveis (AddObject cria com Visible = .F.)
		THIS.TornarControlesVisiveis(THIS.pgf_4c_Principal.Page1)
		THIS.TornarControlesVisiveis(THIS.pgf_4c_Principal.Page2)
	ENDPROC

	*===========================================================================
	* METODO: AdicionarPageFrame
	*===========================================================================
	PROTECTED PROCEDURE AdicionarPageFrame()
		THIS.AddObject("pgf_4c_Principal", "PageFrame")

		WITH THIS.pgf_4c_Principal
			.Left = 0
			.Top = 0  && NÃO é -29 (confirmado na verificação)
			.Width = 1003
			.Height = 631
			.PageCount = 2
			.Tabs = .F.  && Esconder abas
			.Page1.Caption = "Lista"
			.Page2.Caption = "Dados"
			.ActivePage = 1
			.Visible = .T.
		ENDWITH
	ENDPROC

	*===========================================================================
	* METODO: ConfigurarPage1 (Lista)
	*===========================================================================
	PROTECTED PROCEDURE ConfigurarPage1()
		LOCAL loc_oPage1
		loc_oPage1 = THIS.pgf_4c_Principal.Page1

		*-- Container cabeçalho (cnt_4c_Cabecalho = cntSombra original)
		loc_oPage1.AddObject("cnt_4c_Cabecalho", "Container")
		WITH loc_oPage1.cnt_4c_Cabecalho
			.Top = 1  && EXATO do original (sem compensação)
			.Left = 0
			.Width = 1000
			.Height = 80
			.BackColor = RGB(240, 240, 240)
			.Visible = .T.
		ENDWITH

		*-- Label título dentro do cabeçalho
		loc_oPage1.cnt_4c_Cabecalho.AddObject("lbl_4c_Titulo", "Label")
		WITH loc_oPage1.cnt_4c_Cabecalho.lbl_4c_Titulo
			.Top = 25
			.Left = 30
			.Width = 400
			.Height = 30
			.FontName = "Tahoma"
			.FontSize = 16
			.FontBold = .T.
			.Caption = "Cadastro de Produtos"
			.ForeColor = RGB(90, 90, 90)
			.BackStyle = 0  && Transparent
			.Visible = .T.
		ENDWITH

		*-- Container botões CRUD (cnt_4c_Botoes = Grupo_op original)
		loc_oPage1.AddObject("cnt_4c_Botoes", "Container")
		WITH loc_oPage1.cnt_4c_Botoes
			.Top = -1  && EXATO do original (Top negativo CONFIRMADO)
			.Left = 542
			.Width = 380
			.Height = 85
			.BackStyle = 0
			.BorderWidth = 0
			.Visible = .T.
		ENDWITH

		*-- Botões CRUD (criar manualmente)
		LOCAL loc_cIconPath
		loc_cIconPath = gc_4c_CaminhoIcones

		*-- Botão Incluir
		loc_oPage1.cnt_4c_Botoes.AddObject("cmd_4c_Incluir", "CommandButton")
		WITH loc_oPage1.cnt_4c_Botoes.cmd_4c_Incluir
			.Caption = "Incluir"
			.Width = 75
			.Height = 75
			.Left = 5
			.Top = 5
			.Picture = loc_cIconPath + "btn_incluir.jpg"
			.PicturePosition = 13  && Ícone acima do texto
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage1.cnt_4c_Botoes.cmd_4c_Incluir, "Click", THIS, "BtnIncluirClick")

		*-- Botão Consultar
		loc_oPage1.cnt_4c_Botoes.AddObject("cmd_4c_Consultar", "CommandButton")
		WITH loc_oPage1.cnt_4c_Botoes.cmd_4c_Consultar
			.Caption = "Consultar"
			.Width = 75
			.Height = 75
			.Left = 80
			.Top = 5
			.Picture = loc_cIconPath + "btn_consultar.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage1.cnt_4c_Botoes.cmd_4c_Consultar, "Click", THIS, "BtnConsultarClick")

		*-- Botão Alterar
		loc_oPage1.cnt_4c_Botoes.AddObject("cmd_4c_Alterar", "CommandButton")
		WITH loc_oPage1.cnt_4c_Botoes.cmd_4c_Alterar
			.Caption = "Alterar"
			.Width = 75
			.Height = 75
			.Left = 155
			.Top = 5
			.Picture = loc_cIconPath + "btn_alterar.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage1.cnt_4c_Botoes.cmd_4c_Alterar, "Click", THIS, "BtnAlterarClick")

		*-- Botão Excluir
		loc_oPage1.cnt_4c_Botoes.AddObject("cmd_4c_Excluir", "CommandButton")
		WITH loc_oPage1.cnt_4c_Botoes.cmd_4c_Excluir
			.Caption = "Excluir"
			.Width = 75
			.Height = 75
			.Left = 230
			.Top = 5
			.Picture = loc_cIconPath + "btn_excluir.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage1.cnt_4c_Botoes.cmd_4c_Excluir, "Click", THIS, "BtnExcluirClick")

		*-- Botão Procurar
		loc_oPage1.cnt_4c_Botoes.AddObject("cmd_4c_Procurar", "CommandButton")
		WITH loc_oPage1.cnt_4c_Botoes.cmd_4c_Procurar
			.Caption = "Procurar"
			.Width = 75
			.Height = 75
			.Left = 305
			.Top = 5
			.Picture = loc_cIconPath + "btn_procurar.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage1.cnt_4c_Botoes.cmd_4c_Procurar, "Click", THIS, "BtnProcurarClick")

		*-- Container botão Sair (cnt_4c_BotoesSaida = Grupo_Saida original)
		loc_oPage1.AddObject("cnt_4c_BotoesSaida", "Container")
		WITH loc_oPage1.cnt_4c_BotoesSaida
			.Top = -1  && EXATO do original (Top negativo CONFIRMADO)
			.Left = 917
			.Width = 80
			.Height = 85
			.BackStyle = 0
			.BorderWidth = 0
			.Visible = .T.
		ENDWITH

		*-- Botão Sair
		loc_oPage1.cnt_4c_BotoesSaida.AddObject("cmd_4c_Sair", "CommandButton")
		WITH loc_oPage1.cnt_4c_BotoesSaida.cmd_4c_Sair
			.Caption = "Sair"
			.Width = 75
			.Height = 75
			.Left = 5
			.Top = 5
			.Picture = loc_cIconPath + "btn_sair.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage1.cnt_4c_BotoesSaida.cmd_4c_Sair, "Click", THIS, "BtnSairClick")

		*-- Grid de dados (grd_4c_Dados = Grade original)
		loc_oPage1.AddObject("grd_4c_Dados", "GridBase")
		WITH loc_oPage1.grd_4c_Dados
			.Top = 173  && EXATO do original
			.Left = 38
			.Width = 922
			.Height = 409
			.RecordSourceType = 1  && Alias
			.RecordSource = ""  && Será definido em CarregarLista()
			.DeleteMark = .F.
			.ReadOnly = .T.
			.ColumnCount = 7  && FASE 1: 7 colunas (modo padrão, Tipo2=.F.)
			.Visible = .T.
		ENDWITH

		*-- Bind eventos do grid
		BINDEVENT(loc_oPage1.grd_4c_Dados, "DblClick", THIS, "GridDblClick")
	ENDPROC

	*===========================================================================
	* METODO: ConfigurarColunasGrid
	*===========================================================================
	PROTECTED PROCEDURE ConfigurarColunasGrid()
		LOCAL loc_oGrid

		*-- Só executar se o cursor existir
		IF !USED("cursor_4c_Lista")
			RETURN
		ENDIF

		loc_oGrid = THIS.pgf_4c_Principal.Page1.grd_4c_Dados

		WITH loc_oGrid
			*-- Coluna 1: Código
			.Column1.Width = 110
			.Column1.Header1.Caption = "C" + CHR(243) + "digo"
			.Column1.ControlSource = "cursor_4c_Lista.cpros"
			.Column1.ReadOnly = .T.

			*-- Coluna 2: Descrição
			.Column2.Width = 408
			.Column2.Header1.Caption = "Descri" + CHR(231) + CHR(227) + "o"
			.Column2.ControlSource = "cursor_4c_Lista.dpros"
			.Column2.ReadOnly = .T.

			*-- Coluna 3: Grupo (VISÍVEL no modo padrão)
			.Column3.Width = 40
			.Column3.Header1.Caption = "Grp"
			.Column3.ControlSource = "cursor_4c_Lista.cgrus"
			.Column3.ReadOnly = .T.

			*-- Coluna 4: Subgrupo
			.Column4.Width = 70
			.Column4.Header1.Caption = "SubGrp"
			.Column4.ControlSource = "cursor_4c_Lista.sgrus"
			.Column4.ReadOnly = .T.

			*-- Coluna 5: Ref. Fornecedor
			.Column5.Width = 150
			.Column5.Header1.Caption = "Ref. Fornecedor"
			.Column5.ControlSource = "cursor_4c_Lista.reffs"
			.Column5.ReadOnly = .T.

			*-- Coluna 6: Coleção/Grp.Venda
			.Column6.Width = 100
			.Column6.Header1.Caption = "Grp.Venda"
			.Column6.ControlSource = "cursor_4c_Lista.colecoes"
			.Column6.ReadOnly = .T.

			*-- Coluna 7: Imprimir Etiquetas (Checkbox)
			.Column7.Width = 16
			.Column7.Header1.Caption = ""
			.Column7.ControlSource = "cursor_4c_Lista.impEtiqs"
			.Column7.Sparse = .F.  && Checkbox sempre visível
			.Column7.ReadOnly = .T.

			*-- Aplicar fonte Arial 8 para todas as colunas
			LOCAL loc_i
			FOR loc_i = 1 TO 7
				.Columns(loc_i).FontName = "Arial"
				.Columns(loc_i).FontSize = 8
			ENDFOR
		ENDWITH
	ENDPROC

	*===========================================================================
	* METODO: ConfigurarPage2 (Dados - FASE 2: com pgframeDados aninhado)
	*===========================================================================
	PROTECTED PROCEDURE ConfigurarPage2()
		LOCAL loc_oPage2, loc_oPgframeDados, loc_oPgDados
		LOCAL loc_nTopAtual, loc_nColuna1, loc_nColuna2, loc_cIconPath
		loc_oPage2 = THIS.pgf_4c_Principal.Page2
		loc_cIconPath = gc_4c_CaminhoIcones

		*-- Container botões Salvar/Cancelar (cnt_4c_BotoesAcao = Grupo_Salva original)
		*-- IMPORTANTE: Botões ficam FORA do pgframeDados, diretos na Page2
		loc_oPage2.AddObject("cnt_4c_BotoesAcao", "Container")
		WITH loc_oPage2.cnt_4c_BotoesAcao
			.Top = 5
			.Left = 842
			.Width = 160
			.Height = 85
			.BackStyle = 0
			.BorderWidth = 0
			.Visible = .T.
		ENDWITH

		*-- Botões Confirmar/Cancelar (criar manualmente)
		*-- Botão Confirmar
		loc_oPage2.cnt_4c_BotoesAcao.AddObject("cmd_4c_Confirmar", "CommandButton")
		WITH loc_oPage2.cnt_4c_BotoesAcao.cmd_4c_Confirmar
			.Caption = "Confirmar"
			.Width = 75
			.Height = 75
			.Left = 5
			.Top = 5
			.Picture = loc_cIconPath + "btn_confirmar.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage2.cnt_4c_BotoesAcao.cmd_4c_Confirmar, "Click", THIS, "BtnConfirmarClick")

		*-- Botão Cancelar
		loc_oPage2.cnt_4c_BotoesAcao.AddObject("cmd_4c_Cancelar", "CommandButton")
		WITH loc_oPage2.cnt_4c_BotoesAcao.cmd_4c_Cancelar
			.Caption = "Cancelar"
			.Width = 75
			.Height = 75
			.Left = 80
			.Top = 5
			.Picture = loc_cIconPath + "btn_cancelar.jpg"
			.PicturePosition = 13
			.BackColor = RGB(255, 255, 255)
			.ForeColor = RGB(90, 90, 90)
			.Themes = .F.
			.SpecialEffect = 0
			.Visible = .T.
		ENDWITH
		BINDEVENT(loc_oPage2.cnt_4c_BotoesAcao.cmd_4c_Cancelar, "Click", THIS, "BtnCancelarClick")

		*-- IMPORTANTE: Trazer container de botões para frente (evitar ser coberto pelo pgframeDados)
		loc_oPage2.cnt_4c_BotoesAcao.ZOrder(0)  && 0 = BringToFront

		*-- =====================================================================
		*-- PGFRAMEDADOS ANINHADO (PageFrame dentro da Page2)
		*-- IMPORTANTE: Top = -54 para esconder as abas (igual ao original)
		*-- =====================================================================
		loc_oPage2.AddObject("pgframeDados", "PageFrame")
		loc_oPgframeDados = loc_oPage2.pgframeDados

		WITH loc_oPgframeDados
			.Left = -1            && Original: -1
			.Top = -54            && Original: -54 (CRITICO - esconde abas!)
			.Width = 1003         && Original: 1003 (EXATO)
			.Height = 656         && Original: 656 (EXATO)
			.PageCount = 1        && FASE 2: Apenas 1 página (pgDados) por enquanto
			.Tabs = .T.           && Mostrar abas
			.TabStyle = 0         && Original: 0
			.TabStretch = 0       && Original: 0
			.Visible = .T.
		ENDWITH

		*-- Configurar primeira página: pgDados
		WITH loc_oPgframeDados.Page1
			.Caption = "Dados Principais"  && Original: "Dados Principais"
			.Name = "pgDados"
			.BackColor = RGB(236, 233, 216)
		ENDWITH

		loc_oPgDados = loc_oPgframeDados.pgDados

		*-- =====================================================================
		*-- CAMPOS DENTRO DO pgDados (15 campos básicos - POSIÇÕES EXATAS DO ORIGINAL)
		*-- Referência: C:\4c\docs\FORMPRODUTO_LAYOUT_ORIGINAL.md
		*-- =====================================================================

		*-- 1. Código (Left=113, Top=130, Width=108, Height=23)
		loc_oPgDados.AddObject("txt_4c_Codigo", "TextBox")
		WITH loc_oPgDados.txt_4c_Codigo
			.Left = 113
			.Top = 130
			.Width = 108
			.Height = 23
			.MaxLength = 14
			.Value = ""
			.Visible = .T.
		ENDWITH

		*-- 2. Descrição (Left=222, Top=130, Width=290, Height=23)
		loc_oPgDados.AddObject("txt_4c_Descricao", "TextBox")
		WITH loc_oPgDados.txt_4c_Descricao
			.Left = 222
			.Top = 130
			.Width = 290
			.Height = 23
			.MaxLength = 65
			.Value = ""
			.Visible = .T.
		ENDWITH

		*-- 3. Situação (Left=735, Top=130, Width=142, Height=25)
		loc_oPgDados.AddObject("opc_4c_Situacao", "OptionGroup")
		WITH loc_oPgDados.opc_4c_Situacao
			.Left = 735
