	*===========================================================================
	* METODO: AdicionarCampoTexto (Helper)
	*===========================================================================
	PROTECTED PROCEDURE AdicionarCampoTexto(par_oContainer, par_cNome, par_cLabel, par_nLeft, par_nTop, par_nWidth)
		LOCAL loc_cNomeLabel, loc_cNomeTexto

		*-- Label
		IF !EMPTY(par_cLabel)
			loc_cNomeLabel = "lbl" + SUBSTR(par_cNome, 4)  && Remove "txt_" → "lbl_4c_XXX"
			par_oContainer.AddObject(loc_cNomeLabel, "Label")
			WITH par_oContainer.&loc_cNomeLabel.
				.Top = par_nTop
				.Left = par_nLeft
				.Width = 140
				.Height = 20
				.Caption = par_cLabel
				.FontName = "Arial"
				.FontSize = 9
				.BackStyle = 0
				.Visible = .T.
			ENDWITH
			par_nTop = par_nTop + 22  && Label acima do campo
		ENDIF

		*-- TextBox
		par_oContainer.AddObject(par_cNome, "TextBox")
		WITH par_oContainer.&par_cNome.
			.Top = par_nTop
			.Left = par_nLeft
			.Width = par_nWidth
			.Height = 22
			.FontName = "Arial"
			.FontSize = 9
			.Value = ""  && IMPORTANTE: Inicializar como string
			.Visible = .T.
		ENDWITH
	ENDPROC

	*===========================================================================
	* METODO: Implement arLookups
	*===========================================================================
	PROTECTED PROCEDURE ImplementarLookups()
		*-- Lookup Grupo (F4/DblClick)
		BINDEVENT(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Grupo, "KeyPress", THIS, "LookupGrupoKeyPress")
		BINDEVENT(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Grupo, "DblClick", THIS, "LookupGrupo")
		BINDEVENT(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Grupo, "LostFocus", THIS, "BuscarDescricaoGrupo")

		*-- Lookup Fornecedor (F4/DblClick)
		BINDEVENT(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Fornecedor, "KeyPress", THIS, "LookupFornecedorKeyPress")
		BINDEVENT(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Fornecedor, "DblClick", THIS, "LookupFornecedor")
		BINDEVENT(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Fornecedor, "LostFocus", THIS, "BuscarDescricaoFornecedor")
	ENDPROC

	*===========================================================================
	* METODO: LookupGrupoKeyPress
	*===========================================================================
	PROCEDURE LookupGrupoKeyPress(tnKeyCode, tnShiftAltCtrl)
		IF tnKeyCode = 286  && F4
			THIS.LookupGrupo()
		ENDIF
	ENDPROC

	*===========================================================================
	* METODO: LookupGrupo
	*===========================================================================
	PROCEDURE LookupGrupo()
		LOCAL loc_oFormBusca, loc_cCodigoSelecionado, loc_cSQL

		*-- SQL para buscar grupos
		loc_cSQL = "SELECT cgrus, dgrus FROM SigCdGrp ORDER BY cgrus"

		*-- Criar formulário de busca
		loc_oFormBusca = CREATEOBJECT("FormBuscaAuxiliar", ;
			loc_cSQL, ;
			"cgrus", ;
			"dgrus", ;
			"Busca de Grupos")

		loc_oFormBusca.Show(1)  && Modal

		*-- Se selecionou algo
		IF !ISNULL(loc_oFormBusca.this_cCodigoSelecionado)
			loc_cCodigoSelecionado = loc_oFormBusca.this_cCodigoSelecionado
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Grupo.Value = loc_cCodigoSelecionado
			THIS.BuscarDescricaoGrupo()
		ENDIF

		loc_oFormBusca.Release()
	ENDPROC

	*===========================================================================
	* METODO: BuscarDescricaoGrupo
	*===========================================================================
	PROCEDURE BuscarDescricaoGrupo()
		LOCAL loc_cCodigo, loc_cSQL, loc_nResultado

		loc_cCodigo = ALLTRIM(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Grupo.Value)

		IF EMPTY(loc_cCodigo)
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescGrupo.Value = ""
			RETURN
		ENDIF

		loc_cSQL = "SELECT dgrus FROM SigCdGrp WHERE cgrus = " + EscaparSQL(loc_cCodigo)
		loc_nResultado = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_Verifica")

		IF loc_nResultado < 0
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescGrupo.Value = "*** ERRO ***"
			RETURN
		ENDIF

		IF RECCOUNT("cursor_4c_Verifica") = 0
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescGrupo.Value = "*** N" + CHR(195) + "O ENCONTRADO ***"
		ELSE
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescGrupo.Value = ALLTRIM(cursor_4c_Verifica.dgrus)
		ENDIF

		USE IN SELECT("cursor_4c_Verifica")
	ENDPROC

	*===========================================================================
	* METODO: LookupFornecedorKeyPress
	*===========================================================================
	PROCEDURE LookupFornecedorKeyPress(tnKeyCode, tnShiftAltCtrl)
		IF tnKeyCode = 286  && F4
			THIS.LookupFornecedor()
		ENDIF
	ENDPROC

	*===========================================================================
	* METODO: LookupFornecedor
	*===========================================================================
	PROCEDURE LookupFornecedor()
		LOCAL loc_oFormBusca, loc_cCodigoSelecionado, loc_cSQL

		*-- SQL para buscar fornecedores
		loc_cSQL = "SELECT ifors, dfors FROM SigCdFor ORDER BY dfors"

		*-- Criar formulário de busca
		loc_oFormBusca = CREATEOBJECT("FormBuscaAuxiliar", ;
			loc_cSQL, ;
			"ifors", ;
			"dfors", ;
			"Busca de Fornecedores")

		loc_oFormBusca.Show(1)  && Modal

		*-- Se selecionou algo
		IF !ISNULL(loc_oFormBusca.this_cCodigoSelecionado)
			loc_cCodigoSelecionado = loc_oFormBusca.this_cCodigoSelecionado
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Fornecedor.Value = loc_cCodigoSelecionado
			THIS.BuscarDescricaoFornecedor()
		ENDIF

		loc_oFormBusca.Release()
	ENDPROC

	*===========================================================================
	* METODO: BuscarDescricaoFornecedor
	*===========================================================================
	PROCEDURE BuscarDescricaoFornecedor()
		LOCAL loc_cCodigo, loc_cSQL, loc_nResultado

		loc_cCodigo = ALLTRIM(THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_Fornecedor.Value)

		IF EMPTY(loc_cCodigo)
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescFornecedor.Value = ""
			RETURN
		ENDIF

		loc_cSQL = "SELECT dfors FROM SigCdFor WHERE ifors = " + EscaparSQL(loc_cCodigo)
		loc_nResultado = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_Verifica")

		IF loc_nResultado < 0
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescFornecedor.Value = "*** ERRO ***"
			RETURN
		ENDIF

		IF RECCOUNT("cursor_4c_Verifica") = 0
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescFornecedor.Value = "*** N" + CHR(195) + "O ENCONTRADO ***"
		ELSE
			THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados.txt_4c_DescFornecedor.Value = ALLTRIM(cursor_4c_Verifica.dfors)
		ENDIF

		USE IN SELECT("cursor_4c_Verifica")
	ENDPROC

	*===========================================================================
	* METODO: CarregarLista (OVERRIDE)
	*===========================================================================
	PROTECTED PROCEDURE CarregarLista()
		LOCAL loc_cSQL, loc_nResultado

		*-- IMPORTANTE: Não executar durante validação de UI
		IF TYPE("gb_4c_ValidandoUI") = "L" AND gb_4c_ValidandoUI
			RETURN .T.
		ENDIF

		*-- SQL para carregar lista de produtos (FASE 1: campos básicos)
		loc_cSQL = ""
		loc_cSQL = loc_cSQL + "SELECT "
		loc_cSQL = loc_cSQL + "  cpros, dpros, dpro2s, cgrus, sgrus, "
		loc_cSQL = loc_cSQL + "  reffs, colecoes, impEtiqs "
		loc_cSQL = loc_cSQL + "FROM SigCdPro "
		loc_cSQL = loc_cSQL + "ORDER BY cpros"

		loc_nResultado = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_Lista")

		IF loc_nResultado < 0
			MostrarErro("Erro ao carregar lista de produtos", loc_cSQL)
			RETURN .F.
		ENDIF

		*-- Bind RecordSource ao grid
		THIS.pgf_4c_Principal.Page1.grd_4c_Dados.RecordSource = "cursor_4c_Lista"

		*-- CRÍTICO: Reconfigurar cabeçalhos APÓS definir RecordSource
		THIS.ConfigurarColunasGrid()

		RETURN .T.
	ENDPROC

	*===========================================================================
	* METODO: BOParaForm (OVERRIDE)
	*===========================================================================
	PROTECTED PROCEDURE BOParaForm()
		LOCAL loc_oPgDados
		loc_oPgDados = THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados

		WITH THIS.this_oBusinessObject
			loc_oPgDados.txt_4c_Codigo.Value = .this_cCodigo
			loc_oPgDados.txt_4c_Descricao.Value = .this_cDescricao
			loc_oPgDados.txt_4c_CodigoBarras.Value = TRANSFORM(.this_nCodigoBarras, "99999999999999")
			loc_oPgDados.txt_4c_Grupo.Value = .this_cGrupo
			loc_oPgDados.txt_4c_Fornecedor.Value = .this_cFornecedor
			loc_oPgDados.txt_4c_RefFornecedor.Value = .this_cRefFornecedor
			loc_oPgDados.txt_4c_CustoFornecedor.Value = TRANSFORM(.this_nCustoFornecedor, "999999999.999")
			loc_oPgDados.txt_4c_PrecoVenda.Value = TRANSFORM(.this_nPrecoVenda, "999999999.99999")
			loc_oPgDados.txt_4c_FatorVenda.Value = TRANSFORM(.this_nFatorVenda, "9999.999")
			loc_oPgDados.txt_4c_ObsPessoal.Value = .this_cObsPessoal
			loc_oPgDados.txt_4c_ObsPedidos.Value = .this_cObsPedidos
			loc_oPgDados.opc_4c_Situacao.Value = IIF(.this_nSituacao = 1, 1, 2)
			loc_oPgDados.txt_4c_DataInclusao.Value = DTOC(.this_dDataInclusao)
		ENDWITH

		*-- Buscar descrições (lookups)
		THIS.BuscarDescricaoGrupo()
		THIS.BuscarDescricaoFornecedor()
	ENDPROC

	*===========================================================================
	* METODO: FormParaBO (OVERRIDE)
	*===========================================================================
	PROTECTED PROCEDURE FormParaBO()
		LOCAL loc_oPgDados
		loc_oPgDados = THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados

		WITH THIS.this_oBusinessObject
			.this_cCodigo = ALLTRIM(loc_oPgDados.txt_4c_Codigo.Value)
			.this_cDescricao = ALLTRIM(loc_oPgDados.txt_4c_Descricao.Value)
			.this_nCodigoBarras = VAL(ALLTRIM(loc_oPgDados.txt_4c_CodigoBarras.Value))
			.this_cGrupo = ALLTRIM(loc_oPgDados.txt_4c_Grupo.Value)
			.this_cFornecedor = ALLTRIM(loc_oPgDados.txt_4c_Fornecedor.Value)
			.this_cRefFornecedor = ALLTRIM(loc_oPgDados.txt_4c_RefFornecedor.Value)
			.this_nCustoFornecedor = VAL(ALLTRIM(loc_oPgDados.txt_4c_CustoFornecedor.Value))
			.this_nPrecoVenda = VAL(ALLTRIM(loc_oPgDados.txt_4c_PrecoVenda.Value))
			.this_nFatorVenda = VAL(ALLTRIM(loc_oPgDados.txt_4c_FatorVenda.Value))
			.this_cObsPessoal = ALLTRIM(loc_oPgDados.txt_4c_ObsPessoal.Value)
			.this_cObsPedidos = ALLTRIM(loc_oPgDados.txt_4c_ObsPedidos.Value)
			.this_nSituacao = IIF(loc_oPgDados.opc_4c_Situacao.Value = 1, 1, 0)
			*-- Data inclusão não é alterada (gerada automaticamente no INSERT)
		ENDWITH
	ENDPROC

	*===========================================================================
	* METODO: ValidarDados (OVERRIDE)
	*===========================================================================
	PROTECTED PROCEDURE ValidarDados()
		LOCAL loc_oPgDados
		loc_oPgDados = THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados

		*-- Código obrigatório
		IF EMPTY(ALLTRIM(loc_oPgDados.txt_4c_Codigo.Value))
			MsgErro("C" + CHR(243) + "digo do produto " + CHR(233) + " obrigat" + CHR(243) + "rio!")
			loc_oPgDados.txt_4c_Codigo.SetFocus()
			RETURN .F.
		ENDIF

		*-- Descrição obrigatória
		IF EMPTY(ALLTRIM(loc_oPgDados.txt_4c_Descricao.Value))
			MsgErro("Descri" + CHR(231) + CHR(227) + "o " + CHR(233) + " obrigat" + CHR(243) + "ria!")
			loc_oPgDados.txt_4c_Descricao.SetFocus()
			RETURN .F.
		ENDIF

		*-- Grupo obrigatório
		IF EMPTY(ALLTRIM(loc_oPgDados.txt_4c_Grupo.Value))
			MsgErro("Grupo " + CHR(233) + " obrigat" + CHR(243) + "rio!")
			loc_oPgDados.txt_4c_Grupo.SetFocus()
			RETURN .F.
		ENDIF

		*-- Custo >= 0
		IF VAL(ALLTRIM(loc_oPgDados.txt_4c_CustoFornecedor.Value)) < 0
			MsgErro("Custo n" + CHR(227) + "o pode ser negativo!")
			loc_oPgDados.txt_4c_CustoFornecedor.SetFocus()
			RETURN .F.
		ENDIF

		*-- Preço >= 0
		IF VAL(ALLTRIM(loc_oPgDados.txt_4c_PrecoVenda.Value)) < 0
			MsgErro("Pre" + CHR(231) + "o n" + CHR(227) + "o pode ser negativo!")
			loc_oPgDados.txt_4c_PrecoVenda.SetFocus()
			RETURN .F.
		ENDIF

		RETURN .T.
	ENDPROC

	*===========================================================================
	* METODOS: Button Click Handlers
	*===========================================================================

	PROCEDURE BtnIncluirClick()
		THIS.this_cModoAtual = "INCLUIR"
		THIS.this_lNovoRegistro = .T.
		THIS.this_oBusinessObject.NovoRegistro()
		THIS.BOParaForm()
		THIS.HabilitarCampos(.T., .T.)
		THIS.AjustarBotoesPorModo()
		THIS.pgf_4c_Principal.ActivePage = 2
		THIS.pgf_4c_Principal.Page2.txt_4c_Codigo.SetFocus()
	ENDPROC

	PROCEDURE BtnConsultarClick()
		LOCAL loc_cCodigo
		loc_cCodigo = THIS.ObterCodigoSelecionado()

		IF EMPTY(loc_cCodigo)
			MESSAGEBOX("Selecione um registro!", 48, "Aviso")
			RETURN
		ENDIF

		THIS.this_cModoAtual = "VISUALIZAR"
		THIS.this_lNovoRegistro = .F.
		THIS.this_cCodigoAtual = loc_cCodigo

		IF THIS.this_oBusinessObject.CarregarPorId(loc_cCodigo)
			THIS.BOParaForm()
			THIS.HabilitarCampos(.F., .F.)
			THIS.AjustarBotoesPorModo()
			THIS.pgf_4c_Principal.ActivePage = 2
		ELSE
			MESSAGEBOX("Erro ao carregar registro!", 16, "Erro")
		ENDIF
	ENDPROC

	PROCEDURE BtnAlterarClick()
		LOCAL loc_cCodigo
		loc_cCodigo = THIS.ObterCodigoSelecionado()

		IF EMPTY(loc_cCodigo)
			MESSAGEBOX("Selecione um registro!", 48, "Aviso")
			RETURN
		ENDIF

		THIS.this_cModoAtual = "ALTERAR"
		THIS.this_lNovoRegistro = .F.
		THIS.this_cCodigoAtual = loc_cCodigo

		IF THIS.this_oBusinessObject.CarregarPorId(loc_cCodigo)
			THIS.BOParaForm()
			THIS.HabilitarCampos(.T., .F.)
			THIS.AjustarBotoesPorModo()
			THIS.pgf_4c_Principal.ActivePage = 2
			THIS.pgf_4c_Principal.Page2.txt_4c_Descricao.SetFocus()
		ELSE
			MESSAGEBOX("Erro ao carregar registro!", 16, "Erro")
		ENDIF
	ENDPROC

	PROCEDURE BtnExcluirClick()
		LOCAL loc_cCodigo
		loc_cCodigo = THIS.ObterCodigoSelecionado()

		IF EMPTY(loc_cCodigo)
			MESSAGEBOX("Selecione um registro!", 48, "Aviso")
			RETURN
		ENDIF

		IF MESSAGEBOX("Confirma a exclus" + CHR(227) + "o do produto " + loc_cCodigo + "?", 4 + 32, "Confirma" + CHR(231) + CHR(227) + "o") = 6
			IF THIS.this_oBusinessObject.CarregarPorId(loc_cCodigo)
				IF THIS.this_oBusinessObject.Excluir()
					MESSAGEBOX("Registro exclu" + CHR(237) + "do com sucesso!", 64, "Sucesso")
					THIS.CarregarLista()
				ELSE
					MESSAGEBOX(THIS.this_oBusinessObject.this_cMensagemErro, 16, "Erro")
				ENDIF
			ENDIF
		ENDIF
	ENDPROC

	PROCEDURE BtnProcurarClick()
		LOCAL loc_cBusca, loc_oGrid
		loc_cBusca = INPUTBOX("Digite o c" + CHR(243) + "digo ou descri" + CHR(231) + CHR(227) + "o:", "Buscar")

		IF !EMPTY(loc_cBusca)
			loc_cBusca = UPPER(ALLTRIM(loc_cBusca))
			THIS.this_oBusinessObject.Buscar("UPPER(cpros) LIKE '%" + loc_cBusca + "%' OR UPPER(dpros) LIKE '%" + loc_cBusca + "%'")
		ELSE
			THIS.this_oBusinessObject.Buscar()
		ENDIF

		IF USED("cursor_4c_Dados")
			loc_oGrid = THIS.pgf_4c_Principal.Page1.grd_4c_Dados
			loc_oGrid.RecordSource = "cursor_4c_Dados"

			*-- Reconfigurar ControlSource das colunas
			loc_oGrid.Column1.ControlSource = "cursor_4c_Dados.cpros"
			loc_oGrid.Column2.ControlSource = "cursor_4c_Dados.dpros"
			loc_oGrid.Column3.ControlSource = "cursor_4c_Dados.cgrus"
			loc_oGrid.Column4.ControlSource = "cursor_4c_Dados.ifors"
			loc_oGrid.Column5.ControlSource = "cursor_4c_Dados.reffs"
			loc_oGrid.Column6.ControlSource = "cursor_4c_Dados.custofs"
			loc_oGrid.Column7.ControlSource = "cursor_4c_Dados.pvens"

			*-- Reconfigura cabeçalhos (perdidos ao alterar RecordSource)
			THIS.ConfigurarColunasGrid()

			SELECT cursor_4c_Dados
			GO TOP
			loc_oGrid.Refresh()
		ENDIF
	ENDPROC

	PROCEDURE BtnSairClick()
		THIS.Release()
	ENDPROC

	PROCEDURE GridDblClick()
		THIS.BtnConsultarClick()
	ENDPROC

	PROCEDURE BtnConfirmarClick()
		THIS.FormParaBO()

		*-- Coloca o BO em modo de edição se necessário
		IF THIS.this_cModoAtual = "INCLUIR"
			THIS.this_oBusinessObject.this_lEmEdicao = .T.
			THIS.this_oBusinessObject.this_lNovoRegistro = .T.
		ELSE
			IF THIS.this_cModoAtual = "ALTERAR"
				THIS.this_oBusinessObject.this_lEmEdicao = .T.
				THIS.this_oBusinessObject.this_lNovoRegistro = .F.
			ENDIF
		ENDIF

		IF THIS.this_oBusinessObject.Salvar()
			MESSAGEBOX("Registro salvo com sucesso!", 64, "Sucesso")
			THIS.CarregarLista()
			THIS.pgf_4c_Principal.ActivePage = 1
			THIS.this_cModoAtual = "LISTA"
		ELSE
			MESSAGEBOX(THIS.this_oBusinessObject.this_cMensagemErro, 16, "Erro")
		ENDIF
	ENDPROC

	PROCEDURE BtnCancelarClick()
		IF MESSAGEBOX("Cancelar altera" + CHR(231) + CHR(245) + "es?", 4 + 32, "Confirma" + CHR(231) + CHR(227) + "o") = 6
			THIS.CarregarLista()
			THIS.pgf_4c_Principal.ActivePage = 1
			THIS.this_cModoAtual = "LISTA"
		ENDIF
	ENDPROC

	*===========================================================================
	* METODOS: Auxiliares
	*===========================================================================

	*---------------------------------------------------------------------------
	* AjustarBotoesPorModo - Ajusta botões conforme modo (VISUALIZAR vs EDIÇÃO)
	*---------------------------------------------------------------------------
	PROTECTED PROCEDURE AjustarBotoesPorModo()
		LOCAL loc_oPagina, loc_lVisualizar
		loc_oPagina = THIS.pgf_4c_Principal.Page2
		loc_lVisualizar = (THIS.this_cModoAtual == "VISUALIZAR")

		*-- Confirmar: sempre visível, desabilitado no modo VISUALIZAR
		loc_oPagina.cnt_4c_BotoesAcao.cmd_4c_Confirmar.Visible = .T.
		loc_oPagina.cnt_4c_BotoesAcao.cmd_4c_Confirmar.Enabled = !loc_lVisualizar

		*-- Cancelar: sempre visível e habilitado
		loc_oPagina.cnt_4c_BotoesAcao.cmd_4c_Cancelar.Visible = .T.
		loc_oPagina.cnt_4c_BotoesAcao.cmd_4c_Cancelar.Enabled = .T.
	ENDPROC

	*---------------------------------------------------------------------------
	* HabilitarCampos - Habilita/desabilita campos para edição
	*---------------------------------------------------------------------------
	PROTECTED PROCEDURE HabilitarCampos(par_lHabilitar, par_lHabilitarCodigo)
		LOCAL loc_oPgDados
		loc_oPgDados = THIS.pgf_4c_Principal.Page2.pgframeDados.pgDados

		*-- Código só é editável em modo INCLUIR
		loc_oPgDados.txt_4c_Codigo.Enabled = par_lHabilitarCodigo

		*-- Demais campos (FASE 1 - 15 campos)
		loc_oPgDados.txt_4c_Descricao.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_CodigoBarras.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_Grupo.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_DescGrupo.Enabled = .F.  && Sempre desabilitado (lookup result)
		loc_oPgDados.txt_4c_Fornecedor.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_DescFornecedor.Enabled = .F.  && Sempre desabilitado (lookup result)
		loc_oPgDados.txt_4c_RefFornecedor.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_CustoFornecedor.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_PrecoVenda.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_FatorVenda.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_ObsPessoal.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_ObsPedidos.Enabled = par_lHabilitar
		loc_oPgDados.txt_4c_DataInclusao.Enabled = .F.  && Sempre desabilitado (gerado automaticamente)
	ENDPROC

	*---------------------------------------------------------------------------
	* ObterCodigoSelecionado - Retorna código da linha selecionada no grid
	*---------------------------------------------------------------------------
	PROTECTED PROCEDURE ObterCodigoSelecionado()
		IF USED("cursor_4c_Lista") AND RECCOUNT("cursor_4c_Lista") > 0
			SELECT cursor_4c_Lista
			RETURN ALLTRIM(cursor_4c_Lista.cpros)
		ENDIF
		RETURN ""
	ENDPROC

	*---------------------------------------------------------------------------
	* TornarControlesVisiveis - Torna todos os controles visíveis recursivamente
	* REGRA: Deve iterar Pages E Controls para PageFrames
	* IMPORTANTE: AddObject() cria controles com Visible = .F. por padrão
	*---------------------------------------------------------------------------
	PROTECTED PROCEDURE TornarControlesVisiveis(par_oContainer)
		LOCAL loc_nI, loc_oObjeto

		FOR loc_nI = 1 TO par_oContainer.ControlCount
			loc_oObjeto = par_oContainer.Controls(loc_nI)

			IF VARTYPE(loc_oObjeto) = "O"
				IF PEMSTATUS(loc_oObjeto, "Visible", 5)
					loc_oObjeto.Visible = .T.
				ENDIF

				*-- Trata PageFrame - itera Pages
				IF UPPER(loc_oObjeto.BaseClass) = "PAGEFRAME"
					LOCAL loc_nP
					FOR loc_nP = 1 TO loc_oObjeto.PageCount
						THIS.TornarControlesVisiveis(loc_oObjeto.Pages(loc_nP))
					ENDFOR
				ENDIF

				*-- Trata containers com ControlCount
				IF PEMSTATUS(loc_oObjeto, "ControlCount", 5)
					THIS.TornarControlesVisiveis(loc_oObjeto)
				ENDIF
			ENDIF
		ENDFOR
	ENDPROC

ENDDEFINE
