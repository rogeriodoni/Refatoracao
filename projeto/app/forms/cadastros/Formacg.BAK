*==============================================================================
* Formacg.prg - Formulario de Acesso de Grupos (SIGCDACG)
*
* NOTA: Versao SIMPLIFICADA focada em CRUD basico de grupos.
* Interface completa de permissoes (4 abas, drag-drop, etc.) requer
* migracao especializada que excede padroes CRUD.
*==============================================================================

DEFINE CLASS Formacg AS FormBase
    *-- Propriedades visuais
    Height = 600
    Width = 1000
    Caption = "Acesso de Grupos"
    AutoCenter = .T.
    ShowWindow = 1
    WindowType = 1
    ControlBox = .F.
    TitleBar = 0
    Themes = .F.
    BorderStyle = 2

    this_oBusinessObject = .NULL.

    PROCEDURE Init()
        RETURN DODEFAULT()
    ENDPROC

    PROTECTED PROCEDURE InicializarForm()
        LOCAL loc_lSucesso
        loc_lSucesso = .F.

        TRY
            THIS.this_oBusinessObject = CREATEOBJECT("acgBO")

            IF ISNULL(THIS.this_oBusinessObject)
                MostrarErro("Erro ao criar Business Object", "Erro")
                loc_lSucesso = .F.
            ENDIF

            IF TYPE("gb_4c_ValidandoUI") != "L" OR !gb_4c_ValidandoUI
                IF TYPE("gnConnHandle") != "N" OR gnConnHandle < 0
                    MostrarErro("Erro de conexao", "Erro")
                    loc_lSucesso = .F.
                ENDIF
            ENDIF

            THIS.ConfigurarPageFrame()
            THIS.ConfigurarPaginaLista()
            THIS.ConfigurarPaginaDados()

            IF TYPE("gb_4c_ValidandoUI") != "L" OR !gb_4c_ValidandoUI
                IF !THIS.CarregarLista()
                    * Nao impede abertura
                ENDIF
            ENDIF

            THIS.pgf_4c_Paginas.ActivePage = 1
            THIS.this_cModoAtual = "LISTA"
            loc_lSucesso = .T.

        CATCH TO loException
            LOCAL loc_cMsgErro
            loc_cMsgErro = "Erro: " + loException.Message + CHR(13) + ;
                           "Linha: " + TRANSFORM(loException.LineNo) + CHR(13) + ;
                           "Procedure: " + loException.Procedure + CHR(13) + ;
                           "Details: " + loException.Details
            MostrarErro(loc_cMsgErro, "Erro Detalhado")
        ENDTRY

        RETURN loc_lSucesso
    ENDPROC

    PROTECTED PROCEDURE ConfigurarPageFrame()
        THIS.AddObject("pgf_4c_Paginas", "PageFrame")
        THIS.pgf_4c_Paginas.Themes = .F.

        WITH THIS.pgf_4c_Paginas
            .Top = -29
            .Left = 0
            .Width = 1000
            .Height = 629
            .PageCount = 2
            .Tabs = .F.
            .BorderWidth = 0
            .Page1.Caption = "Lista"
            .Page2.Caption = "Dados"
            .Visible = .T.
        ENDWITH

        *-- Set BackColor after WITH block
        THIS.pgf_4c_Paginas.BackColor = RGB(255, 255, 255)
        THIS.pgf_4c_Paginas.Page1.BackColor = RGB(255, 255, 255)
        THIS.pgf_4c_Paginas.Page2.BackColor = RGB(255, 255, 255)
    ENDPROC

    PROTECTED PROCEDURE ConfigurarPaginaLista()
        LOCAL loc_oPagina
        loc_oPagina = THIS.pgf_4c_Paginas.Page1

        *-- Container cabecalho
        loc_oPagina.AddObject("cnt_4c_Cabecalho", "Container")
        WITH loc_oPagina.cnt_4c_Cabecalho
            .Top = 31
            .Left = 0
            .Width = 1000
            .Height = 80
            .BackStyle = 0
            .BorderWidth = 0
        ENDWITH

        *-- Label titulo
        loc_oPagina.cnt_4c_Cabecalho.AddObject("lbl_4c_Titulo", "Label")
        WITH loc_oPagina.cnt_4c_Cabecalho.lbl_4c_Titulo
            .Caption = "Acesso de Grupos"
            .Top = 30
            .Left = 20
            .Width = 300
            .Height = 25
            .FontName = "Tahoma"
            .FontSize = 14
            .FontBold = .T.
            .BackStyle = 0
            .ForeColor = RGB(90, 90, 90)
        ENDWITH

        *-- Container botoes
        loc_oPagina.AddObject("cnt_4c_Botoes", "Container")
        WITH loc_oPagina.cnt_4c_Botoes
            .Top = 29
