    *--------------------------------------------------------------------------
    * InicializarValores - Inicializa valores dos controles
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE InicializarValores()
        THIS.txt_4c_DataInicial.Value = {}
        THIS.txt_4c_DataFinal.Value = {}
        THIS.txt_4c_Situacao.Value = ""
        THIS.opt_4c_Bloqueio.Value = 1
        THIS.opt_4c_Opcao.Value = 1
        THIS.cnt_4c_Aguarde.Visible = .F.
    ENDPROC

    *--------------------------------------------------------------------------
    * ValidarDataInicial - Valida data inicial
    *--------------------------------------------------------------------------
    PROCEDURE ValidarDataInicial()
        IF !EMPTY(THIS.txt_4c_DataInicial.Value)
            IF THIS.txt_4c_DataInicial.Value > THIS.txt_4c_DataFinal.Value
                THIS.txt_4c_DataFinal.Value = THIS.txt_4c_DataInicial.Value
            ENDIF
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * ValidarSituacao - Valida e busca situacao
    *--------------------------------------------------------------------------
    PROCEDURE ValidarSituacao()
        LOCAL loc_oBusca, loc_cSQL, loc_nResultado, loc_lContinuar
        loc_lContinuar = .T.

        IF !EMPTY(THIS.txt_4c_Situacao.Value)
            TRY
                * Busca situacao
                TEXT TO loc_cSQL NOSHOW
                    SELECT Codigos, Descrs
                    FROM SigCdCst
                    WHERE NOT Autos = 2
                ENDTEXT

                loc_nResultado = SQLEXEC(gnConnHandle, loc_cSQL, "crListaRemota")

                IF loc_nResultado < 0
                    MostrarErro("Erro ao buscar situa" + CHR(231) + CHR(245) + "es:" + CHR(13) + CapturarErroSQL(), "Erro SQL")
                    loc_lContinuar = .F.
                ENDIF

                IF loc_lContinuar
                    SELECT crListaRemota
                    INDEX ON Codigos TAG Codigos
                    INDEX ON Descrs + Codigos TAG Descrs

                    SET NEAR ON
                    IF !SEEK(THIS.txt_4c_Situacao.Value, "crListaRemota", "Codigos")
                        * Abre busca
                        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, "SigCdCst", "cursor_4c_Busca", "Codigos", THIS.txt_4c_Situacao.Value, "Situa" + CHR(231) + CHR(245) + "es")

                        * Adicionar colunas ao grid
                        loc_oBusca.mAddColuna("Codigos", "", "C" + CHR(243) + "digo")
                        loc_oBusca.mAddColuna("Descrs", "", "Descri" + CHR(231) + CHR(227) + "o")

                        * Mostrar modal
                        loc_oBusca.Show(1)

                        * Verificar selecao
                        IF loc_oBusca.this_lSelecionou
                            IF USED("cursor_4c_Busca")
                                THIS.txt_4c_Situacao.Value = ALLTRIM(cursor_4c_Busca.Codigos)
                            ENDIF
                        ELSE
                            THIS.txt_4c_Situacao.Value = ""
                        ENDIF

                        * Limpar
                        IF USED("cursor_4c_Busca")
                            USE IN cursor_4c_Busca
                        ENDIF
                        loc_oBusca.Release()
                    ELSE
                        THIS.txt_4c_Situacao.Value = ALLTRIM(crListaRemota.Codigos)
                    ENDIF
                    SET NEAR OFF

                    IF USED("crListaRemota")
                        USE IN crListaRemota
                    ENDIF
                ENDIF

            CATCH TO loException
                MostrarErro("Erro ao validar situa" + CHR(231) + CHR(227) + "o:" + CHR(13) + loException.Message, "Erro")
            ENDTRY
        ENDIF

        THIS.Refresh()
    ENDPROC

    *--------------------------------------------------------------------------
    * SituacaoKeyPress - Trata tecla F4 para lookup
    *--------------------------------------------------------------------------
    PROCEDURE SituacaoKeyPress(nKeyCode, nShiftAltCtrl)
        IF nKeyCode = 286  && F4
            THIS.ValidarSituacao()
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * BloqueioChange - Trata mudanca do optiongroup bloqueio
    *--------------------------------------------------------------------------
    PROCEDURE BloqueioChange()
        IF THIS.opt_4c_Bloqueio.Value = 2  && Desbloqueio
            THIS.opt_4c_Opcao.Value = 3  && Ambos
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnProcessarClick - Processa bloqueio/desbloqueio
    *--------------------------------------------------------------------------
    PROCEDURE BtnProcessarClick()
        LOCAL loc_lSucesso, loc_cTitulo, loc_lContinuar
        loc_lSucesso = .F.
        loc_lContinuar = .T.

        TRY
            * Transfere valores para BO
            THIS.this_oBusinessObject.this_dDataInicial = THIS.txt_4c_DataInicial.Value
            THIS.this_oBusinessObject.this_dDataFinal = THIS.txt_4c_DataFinal.Value
            THIS.this_oBusinessObject.this_cSituacao = ALLTRIM(THIS.txt_4c_Situacao.Value)
            THIS.this_oBusinessObject.this_nOpcaoBloqueio = THIS.opt_4c_Bloqueio.Value
            THIS.this_oBusinessObject.this_nOpcaoFiltro = THIS.opt_4c_Opcao.Value

            * Valida parametros
            IF !THIS.this_oBusinessObject.ValidarParametros()
                loc_lContinuar = .F.
            ENDIF

            IF loc_lContinuar
                * Mostra mensagem aguarde
                THIS.cnt_4c_Aguarde.Visible = .T.
                THIS.Refresh()

                * Cria cursor de cabecalho
                CREATE CURSOR crCabecalho (Titulo c(200))
                loc_cTitulo = THIS.this_oBusinessObject.ObterTituloRelatorio()
                INSERT INTO crCabecalho (Titulo) VALUES (loc_cTitulo)

                * Busca ultimo vencimento
                IF !THIS.this_oBusinessObject.BuscarUltimoVencimento()
                    THIS.cnt_4c_Aguarde.Visible = .F.
                    loc_lContinuar = .F.
                ENDIF
            ENDIF

            IF loc_lContinuar
                * Busca contas a processar
                IF !THIS.this_oBusinessObject.BuscarContasProcessar()
                    THIS.cnt_4c_Aguarde.Visible = .F.
                    loc_lContinuar = .F.
                ENDIF
            ENDIF

            IF loc_lContinuar
                * Cria cursor final
                IF !THIS.this_oBusinessObject.CriarCursorFinal()
                    THIS.cnt_4c_Aguarde.Visible = .F.
                    loc_lContinuar = .F.
                ENDIF
            ENDIF

            IF loc_lContinuar
                * Mostra relatorio de preview
                REPORT FORM SigBlCta PREVIEW

                * Confirma atualizacao
                IF MESSAGEBOX("Deseja Atualizar as Situa" + CHR(231) + CHR(245) + "es das Contas?", 4+32, "Aten" + CHR(231) + CHR(227) + "o") = 6
                    * Atualiza situacoes
                    loc_lSucesso = THIS.this_oBusinessObject.AtualizarSituacoes()

                    IF loc_lSucesso
                        * Commit
                        IF SQLEXEC(gnConnHandle, "COMMIT TRANSACTION") >= 0
                            MsgSucesso("A Grava" + CHR(231) + CHR(227) + "o Dos Dados Foi Realizada Com Sucesso!")
                        ELSE
                            SQLEXEC(gnConnHandle, "ROLLBACK TRANSACTION")
                            MostrarErro("A Grava" + CHR(231) + CHR(227) + "o Dos Dados N" + CHR(227) + "O Pode Ser Realizada!", "Falha na Grava" + CHR(231) + CHR(227) + "o")
                        ENDIF
                    ELSE
                        * Mostra erros
                        SELECT crErros
                        GO TOP
                        REPLACE Titulo WITH "Erros do Processamento" IN crCabecalho
                        REPORT FORM SigBlCta PREVIEW
                    ENDIF
                ENDIF
            ENDIF

        CATCH TO loException
            MostrarErro("Erro ao processar:" + CHR(13) + loException.Message, "Erro")
        FINALLY
            THIS.cnt_4c_Aguarde.Visible = .F.
            THIS.InicializarValores()
            THIS.Refresh()
        ENDTRY
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnEncerrarClick - Fecha formulario
    *--------------------------------------------------------------------------
    PROCEDURE BtnEncerrarClick()
        THIS.Release()
    ENDPROC

ENDDEFINE
