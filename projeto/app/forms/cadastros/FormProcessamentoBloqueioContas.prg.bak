*==============================================================================
* FormProcessamentoBloqueioContas.prg
* Formulario para Processamento de Bloqueio/Desbloqueio de Contas
*==============================================================================
* Descricao: Processa bloqueio/desbloqueio de contas baseado em criterios
* Autor: Sistema 4C
* Data: 2026-02-05
*==============================================================================

DEFINE CLASS FormProcessamentoBloqueioContas AS Form
    *--------------------------------------------------------------------------
    * Propriedades Visuais (PILAR 1 - UX FIDELITY - copiar do original)
    *--------------------------------------------------------------------------
    BorderStyle = 2
    Height = 230
    Width = 500
    ShowTips = .T.
    AutoCenter = .T.
    Picture = ""  && Sera configurado no Init com caminho correto
    Caption = "Processamento para Bloqueio de Contas"
    ControlBox = .F.
    Closable = .F.
    TitleBar = 0
    WindowState = 0
    ShowWindow = 1
    WindowType = 1
    Themes = .F.

    *--------------------------------------------------------------------------
    * Propriedades
    *--------------------------------------------------------------------------
    this_oBusinessObject = .NULL.

    *--------------------------------------------------------------------------
    * Init
    *--------------------------------------------------------------------------
    PROCEDURE Init()
        LOCAL loc_lSucesso
        loc_lSucesso = .F.

        TRY
            * Configura Picture com caminho correto
            THIS.Picture = gc_4c_CaminhoIcones + "..\framework\imagens\fundo_cadastro.jpg"

            * Cria Business Object
            THIS.this_oBusinessObject = CREATEOBJECT("ProcessamentoBloqueioContaBO")

            IF VARTYPE(THIS.this_oBusinessObject) != "O"
                MostrarErro("Erro ao criar Business Object", "Erro")
                loc_lSucesso = .F.
            ELSE
                * Configura controles
                THIS.ConfigurarControles()
                THIS.InicializarValores()
                loc_lSucesso = .T.
            ENDIF

        CATCH TO loException
            MostrarErro("Erro ao inicializar formul" + CHR(225) + "rio:" + CHR(13) + loException.Message, "Erro")
            loc_lSucesso = .F.
        ENDTRY

        RETURN loc_lSucesso
    ENDPROC

