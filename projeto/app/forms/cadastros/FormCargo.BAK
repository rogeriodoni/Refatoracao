*------------------------------------------------------------------------------
* FormCargo - Formul�rio de Cadastro de Cargos
*------------------------------------------------------------------------------
* Herda de: FormBase
* Business Object: CargoBO
* Tabela: SIGCDCRG
*------------------------------------------------------------------------------

DEFINE CLASS FormCargo AS FormBase
SET STEP ON 
    *-- PROBLEMA 14: Propriedades visuais OBRIGAT�RIAS na DEFINE CLASS
    Height = 600
    Width = 1000
    Caption = "Cadastro de Cargos"
    AutoCenter = .T.
    ShowWindow = 1
    WindowType = 1
    ControlBox = .F.
    TitleBar = 0
    Themes = .F.
    BorderStyle = 2
    FontName = "Tahoma"
    ForeColor = RGB(90,90,90)

    *-- Business Object
    this_oBusinessObject = .NULL.

    *-- Caminho de icones (inicializado no InicializarForm)
    this_cCaminhoIcones = ""

    *--------------------------------------------------------------------------
    * Init - Apenas DODEFAULT (FormBase.Init chama InicializarForm)
    *--------------------------------------------------------------------------
    PROCEDURE Init()
        *-- Inicializar caminho de icones antes de DODEFAULT
        IF TYPE("gc_4c_CaminhoIcones") = "C"
            THIS.this_cCaminhoIcones = gc_4c_CaminhoIcones
        ENDIF
        RETURN DODEFAULT()
    ENDPROC

    *--------------------------------------------------------------------------
    * InicializarForm - Inicializa��o do formul�rio
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE InicializarForm()
        LOCAL loc_lSucesso, loc_lPularCarregamento
        loc_lSucesso = .F.
        loc_lPularCarregamento = .F.

        TRY
            *-- Criar Business Object
            THIS.this_oBusinessObject = CREATEOBJECT("CargoBO")

            IF ISNULL(THIS.this_oBusinessObject)
                MostrarErro("Erro ao criar Business Object CargoBO", "Erro")
                loc_lSucesso = .F.
            ELSE
                THIS.ConfigurarPageFrame()
                THIS.ConfigurarPaginaLista()
                THIS.ConfigurarPaginaDados()

                *-- Carregar lista (pula se estiver validando UI)
                IF TYPE("gb_4c_ValidandoUI") = "L"
                    IF gb_4c_ValidandoUI = .T.
                        loc_lPularCarregamento = .T.
                    ENDIF
                ENDIF
                IF NOT loc_lPularCarregamento
                    IF NOT THIS.CarregarLista()
                        * Falha ao carregar nao impede abertura
                    ENDIF
                ENDIF

                THIS.pgf_4c_Paginas.ActivePage = 1
                THIS.this_cModoAtual = "LISTA"
                loc_lSucesso = .T.
            ENDIF

        CATCH TO loException
            MostrarErro("Erro ao inicializar FormCargo:" + CHR(13) + loException.Message, "Erro")
            loc_lSucesso = .F.
        ENDTRY

        RETURN loc_lSucesso
    ENDPROC

    *--------------------------------------------------------------------------
    * ConfigurarPageFrame - Configura PageFrame com 2 p�ginas
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE ConfigurarPageFrame()
        THIS.AddObject("pgf_4c_Paginas", "PageFrame")

        WITH THIS.pgf_4c_Paginas
            .Top = -29
            .Left = 0
            .Width = 1003
            .Height = 600
            .Tabs = .F.
            .PageCount = 2

            .Page1.Caption = "Lista"
            IF NOT EMPTY(THIS.this_cCaminhoIcones)
                .Page1.Picture = THIS.this_cCaminhoIcones + "fundo_cad_1003.jpg"
            ENDIF
            .Page1.BackColor = RGB(255,255,255)

            .Page2.Caption = "Dados"
            IF NOT EMPTY(THIS.this_cCaminhoIcones)
                .Page2.Picture = THIS.this_cCaminhoIcones + "fundo_cad_1003.jpg"
            ENDIF
            .Page2.BackColor = RGB(255,255,255)

            .Visible = .T.
        ENDWITH
    ENDPROC

