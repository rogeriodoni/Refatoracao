        *-- PROBLEMA 11 e 12: Tornar controles vis�veis (OBRIGAT�RIO)
        THIS.TornarControlesVisiveis(loc_oPagina)
    ENDPROC

    *--------------------------------------------------------------------------
    * ConfigurarGridCentroCusto - Configura as 4 colunas do grid com lookups
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE ConfigurarGridCentroCusto()
        LOCAL loc_oGrid
        loc_oGrid = THIS.pgf_4c_Paginas.Page2.grd_4c_CentroCusto

        *-- Coluna 1: Grupo (lookup para SigCdGcr)
        WITH loc_oGrid.Column1
            .Header1.Caption = "Grupo"
            .Width = 80
            .ControlSource = "cursor_4c_CCLocal.Grupos"

            *-- Remove TextBox padr�o e adiciona custom class com lookup
            IF PEMSTATUS(.Column1, "Text1", 5)
                .RemoveObject("Text1")
            ENDIF
            .AddObject("txtGrupos", "TextBoxGridGrupos")
            .txtGrupos.Visible = .T.
            .CurrentControl = "txtGrupos"
        ENDWITH

        *-- Coluna 2: Conta (lookup para SigReCtb filtrado por Grupo)
        WITH loc_oGrid.Column2
            .Header1.Caption = "Conta"
            .Width = 80
            .ControlSource = "cursor_4c_CCLocal.Contas"

            *-- Remove TextBox padr�o e adiciona custom class com lookup
            IF PEMSTATUS(.Column2, "Text1", 5)
                .RemoveObject("Text1")
            ENDIF
            .AddObject("txtContas", "TextBoxGridContas")
            .txtContas.Visible = .T.
            .CurrentControl = "txtContas"
        ENDWITH

        *-- Coluna 3: Valor (campo num�rico)
        WITH loc_oGrid.Column3
            .Header1.Caption = "Valor"
            .Width = 100
            .ControlSource = "cursor_4c_CCLocal.Valors"
            .Text1.InputMask = "999,999,999.99"
            .Text1.Alignment = 1  && Alinhamento � direita
        ENDWITH

        *-- Coluna 4: Moeda (lookup para SigCdMoe)
        WITH loc_oGrid.Column4
            .Header1.Caption = "Moeda"
            .Width = 50
            .ControlSource = "cursor_4c_CCLocal.Moedas"

            *-- Remove TextBox padr�o e adiciona custom class com lookup
            IF PEMSTATUS(.Column4, "Text1", 5)
                .RemoveObject("Text1")
            ENDIF
            .AddObject("txtMoedas", "TextBoxGridMoedas")
            .txtMoedas.Visible = .T.
            .CurrentControl = "txtMoedas"
        ENDWITH

        loc_oGrid.Refresh()
    ENDPROC

    *--------------------------------------------------------------------------
    * AdicionarLabelECampo - Helper para criar label + textbox
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE AdicionarLabelECampo(par_oContainer, par_cCaption, par_cNomeCampo, ;
                                              par_nLeftLabel, par_nTopLabel, ;
                                              par_nLeftText, par_nTopText, par_nWidthText)
        LOCAL loc_cNomeLabel
        loc_cNomeLabel = "lbl_" + SUBSTR(par_cNomeCampo, 5)  && Remove "txt_"

        IF !EMPTY(par_cCaption)
            par_oContainer.AddObject(loc_cNomeLabel, "Label")
            WITH EVALUATE("par_oContainer." + loc_cNomeLabel)
                .Caption = par_cCaption
                .FontName = "Tahoma"
                .FontSize = 8
                .Left = par_nLeftLabel
                .Top = par_nTopLabel
                .AutoSize = .T.
                .ForeColor = RGB(90,90,90)
                .BackStyle = 0
                .Visible = .T.
            ENDWITH
        ENDIF

        par_oContainer.AddObject(par_cNomeCampo, "TextBox")
        WITH EVALUATE("par_oContainer." + par_cNomeCampo)
            .Value = ""
            .FontName = "Tahoma"
            .FontSize = 8
            .Left = par_nLeftText
            .Top = par_nTopText
            .Width = par_nWidthText
            .Height = 23
            .SpecialEffect = 1
            .BorderColor = RGB(100,100,100)
            .Visible = .T.
        ENDWITH
    ENDPROC

    *--------------------------------------------------------------------------
    * AdicionarLabelECampoNumerico - Helper para label + textbox num�rico
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE AdicionarLabelECampoNumerico(par_oContainer, par_cCaption, par_cNomeCampo, ;
                                                      par_nLeftLabel, par_nTopLabel, ;
                                                      par_nLeftText, par_nTopText, par_nWidthText, ;
                                                      par_cInputMask)
        THIS.AdicionarLabelECampo(par_oContainer, par_cCaption, par_cNomeCampo, ;
                                  par_nLeftLabel, par_nTopLabel, ;
                                  par_nLeftText, par_nTopText, par_nWidthText)

        EVALUATE("par_oContainer." + par_cNomeCampo + ".Value = 0")
        EVALUATE("par_oContainer." + par_cNomeCampo + ".InputMask = [" + par_cInputMask + "]")
    ENDPROC

    *--------------------------------------------------------------------------
    * CarregarLista - PROBLEMA 2: Carrega grid de lista
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE CarregarLista()
        LOCAL loc_oGrid, loc_lResultado
        loc_lResultado = .F.

        TRY
            loc_oGrid = THIS.pgf_4c_Paginas.Page1.grd_4c_Lista

            *-- Buscar dados
            IF !THIS.this_oBusinessObject.Buscar("")
                loc_lResultado = .F.
            ELSE
                *-- PROBLEMA 6: Configurar RecordSource ANTES dos cabe�alhos
                loc_oGrid.RecordSource = "cursor_4c_Dados"
                loc_oGrid.Column1.ControlSource = "cursor_4c_Dados.cods"
                loc_oGrid.Column2.ControlSource = "cursor_4c_Dados.descs"

                *-- PROBLEMA 6: Reconfigurar cabe�alhos AP�S RecordSource
                loc_oGrid.Column1.Width = 100
                loc_oGrid.Column2.Width = 300
                loc_oGrid.Column1.Header1.Caption = "C" + CHR(243) + "digo"
                loc_oGrid.Column2.Header1.Caption = "Descri" + CHR(231) + CHR(227) + "o"

                *-- Formatar grid
                THIS.FormatarGridLista(loc_oGrid)
                loc_lResultado = .T.
            ENDIF

        CATCH TO loException
            MostrarErro("Erro ao carregar lista:" + CHR(13) + loException.Message, "Erro")
            loc_lResultado = .F.
        ENDTRY

        RETURN loc_lResultado
    ENDPROC

    *--------------------------------------------------------------------------
    * PROBLEMA 11: FormatarGridLista - OBRIGAT�RIO implementar no form
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE FormatarGridLista(par_oGrid)
        WITH par_oGrid
            .SetAll("FontName", "Tahoma", "Column")
            .SetAll("FontSize", 8, "Column")
        ENDWITH
    ENDPROC

    *--------------------------------------------------------------------------
    * PROBLEMA 11: TornarControlesVisiveis - OBRIGAT�RIO implementar no form
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE TornarControlesVisiveis(par_oContainer)
        LOCAL loc_nI, loc_oObjeto

        FOR loc_nI = 1 TO par_oContainer.ControlCount
            loc_oObjeto = par_oContainer.Controls(loc_nI)

            IF VARTYPE(loc_oObjeto) = "O"
                IF PEMSTATUS(loc_oObjeto, "Visible", 5)
                    loc_oObjeto.Visible = .T.
                ENDIF

                *-- Trata PageFrame - itera Pages
                IF UPPER(loc_oObjeto.BaseClass) = "PAGEFRAME"
                    LOCAL loc_nP
                    FOR loc_nP = 1 TO loc_oObjeto.PageCount
                        THIS.TornarControlesVisiveis(loc_oObjeto.Pages(loc_nP))
                    ENDFOR
                ENDIF

                *-- Trata containers com ControlCount
                IF PEMSTATUS(loc_oObjeto, "ControlCount", 5)
                    THIS.TornarControlesVisiveis(loc_oObjeto)
                ENDIF
            ENDIF
        ENDFOR
    ENDPROC

    *--------------------------------------------------------------------------
    * FormParaBO - Transfere dados do formul�rio para o Business Object
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE FormParaBO()
        LOCAL loc_oPagina
        loc_oPagina = THIS.pgf_4c_Paginas.Page2

        WITH THIS.this_oBusinessObject
            *-- Campos string
            .this_cCodigo = ALLTRIM(loc_oPagina.txt_4c_Codigo.Value)
            .this_cDescricao = ALLTRIM(loc_oPagina.txt_4c_Descricao.Value)
            .this_cGrupoComis = ALLTRIM(loc_oPagina.txt_4c_GrupoComis.Value)

            *-- Campos num�ricos
            .this_nLimDesconto = loc_oPagina.txt_4c_LimDesconto.Value
            .this_nDescPercent = loc_oPagina.txt_4c_DescPercent.Value
            .this_nLimAcrescimo = loc_oPagina.txt_4c_LimAcrescimo.Value
            .this_nAcresPercent = loc_oPagina.txt_4c_AcresPercent.Value
            .this_nVlLibPag = loc_oPagina.txt_4c_VlLibPag.Value
            .this_nVlLibCot = loc_oPagina.txt_4c_VlLibCot.Value
            .this_nVlLibOpe = loc_oPagina.txt_4c_VlLibOpe.Value
            .this_nVarCot = loc_oPagina.txt_4c_VarCot.Value
            .this_nComissao = loc_oPagina.txt_4c_Comissao.Value
            .this_nFatorComis = loc_oPagina.txt_4c_FatorComis.Value
            .this_nTipoComis = loc_oPagina.opt_4c_TipoComis.Value - 1  && 1-based to 0-based

            *-- Flags S/N
            .this_cNivel = UPPER(ALLTRIM(loc_oPagina.txt_4c_Nivel.Value))
            .this_cAltCot = UPPER(ALLTRIM(loc_oPagina.txt_4c_AltCot.Value))
            .this_cLimite = UPPER(ALLTRIM(loc_oPagina.txt_4c_Limite.Value))
            .this_cCancItem = UPPER(ALLTRIM(loc_oPagina.txt_4c_CancItem.Value))
            .this_cLibFpag = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibFpag.Value))
            .this_cLibFpg = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibFpg.Value))
            .this_cLibSdIns = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibSdIns.Value))
            .this_cLibOpe = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibOpe.Value))
            .this_cFatComis = UPPER(ALLTRIM(loc_oPagina.txt_4c_FatComis.Value))
            .this_cLibAltCli = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibAltCli.Value))
            .this_cLibExPrd = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibExPrd.Value))
            .this_cLibOpers = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibOpers.Value))
            .this_cLibVarPeso = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibVarPeso.Value))
            .this_cLibTroca = UPPER(ALLTRIM(loc_oPagina.txt_4c_LibTroca.Value))

            *-- Flags num�ricos (OptionGroup ou similar) - inferir de campos
            .this_nLibLeilao = IIF(UPPER(ALLTRIM(loc_oPagina.txt_4c_LibLeilao.Value)) = "SIM", 1, 2)
            .this_nLibDupEnd = IIF(UPPER(ALLTRIM(loc_oPagina.txt_4c_LibDupEnd.Value)) = "SIM", 1, 2)
            .this_nLibSldTqe = IIF(UPPER(ALLTRIM(loc_oPagina.txt_4c_LibSldTqe.Value)) = "SIM", 1, 2)
            .this_nLibDupTit = IIF(UPPER(ALLTRIM(loc_oPagina.txt_4c_LibDupTit.Value)) = "SIM", 1, 2)
            .this_nLibPrze = IIF(UPPER(ALLTRIM(loc_oPagina.txt_4c_LibPrze.Value)) = "SIM", 1, 2)
        ENDWITH
    ENDPROC

    *--------------------------------------------------------------------------
    * BOParaForm - Transfere dados do Business Object para o formul�rio
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE BOParaForm()
        LOCAL loc_oPagina
        loc_oPagina = THIS.pgf_4c_Paginas.Page2

        WITH THIS.this_oBusinessObject
            *-- Campos string
            loc_oPagina.txt_4c_Codigo.Value = .this_cCodigo
            loc_oPagina.txt_4c_Descricao.Value = .this_cDescricao
            loc_oPagina.txt_4c_GrupoComis.Value = .this_cGrupoComis

            *-- Campos num�ricos
            loc_oPagina.txt_4c_LimDesconto.Value = .this_nLimDesconto
            loc_oPagina.txt_4c_DescPercent.Value = .this_nDescPercent
            loc_oPagina.txt_4c_LimAcrescimo.Value = .this_nLimAcrescimo
            loc_oPagina.txt_4c_AcresPercent.Value = .this_nAcresPercent
            loc_oPagina.txt_4c_VlLibPag.Value = .this_nVlLibPag
            loc_oPagina.txt_4c_VlLibCot.Value = .this_nVlLibCot
            loc_oPagina.txt_4c_VlLibOpe.Value = .this_nVlLibOpe
            loc_oPagina.txt_4c_VarCot.Value = .this_nVarCot
            loc_oPagina.txt_4c_Comissao.Value = .this_nComissao
            loc_oPagina.txt_4c_FatorComis.Value = .this_nFatorComis
            loc_oPagina.opt_4c_TipoComis.Value = .this_nTipoComis + 1  && 0-based to 1-based

            *-- Flags S/N
            loc_oPagina.txt_4c_Nivel.Value = .this_cNivel
            loc_oPagina.txt_4c_AltCot.Value = .this_cAltCot
            loc_oPagina.txt_4c_Limite.Value = .this_cLimite
            loc_oPagina.txt_4c_CancItem.Value = .this_cCancItem
            loc_oPagina.txt_4c_LibFpag.Value = .this_cLibFpag
            loc_oPagina.txt_4c_LibFpg.Value = .this_cLibFpg
            loc_oPagina.txt_4c_LibSdIns.Value = .this_cLibSdIns
            loc_oPagina.txt_4c_LibOpe.Value = .this_cLibOpe
            loc_oPagina.txt_4c_FatComis.Value = .this_cFatComis
            loc_oPagina.txt_4c_LibAltCli.Value = .this_cLibAltCli
            loc_oPagina.txt_4c_LibExPrd.Value = .this_cLibExPrd
            loc_oPagina.txt_4c_LibOpers.Value = .this_cLibOpers
            loc_oPagina.txt_4c_LibVarPeso.Value = .this_cLibVarPeso
            loc_oPagina.txt_4c_LibTroca.Value = .this_cLibTroca

            *-- Flags num�ricos
            loc_oPagina.txt_4c_LibLeilao.Value = IIF(.this_nLibLeilao = 1, "Sim", "N" + CHR(227) + "o")
            loc_oPagina.txt_4c_LibDupEnd.Value = IIF(.this_nLibDupEnd = 1, "Sim", "N" + CHR(227) + "o")
            loc_oPagina.txt_4c_LibSldTqe.Value = IIF(.this_nLibSldTqe = 1, "Sim", "N" + CHR(227) + "o")
            loc_oPagina.txt_4c_LibDupTit.Value = IIF(.this_nLibDupTit = 1, "Sim", "N" + CHR(227) + "o")
            loc_oPagina.txt_4c_LibPrze.Value = IIF(.this_nLibPrze = 1, "Sim", "N" + CHR(227) + "o")
        ENDWITH
    ENDPROC

