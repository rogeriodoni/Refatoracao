        BINDEVENT(loc_oPagina.cmd_4c_ExcluirGrid, "Click", THIS, "BtnExcluirGridClick")

        *-- Grid de Centro de Custo
        loc_oPagina.AddObject("grd_4c_CentroCusto", "Grid")
