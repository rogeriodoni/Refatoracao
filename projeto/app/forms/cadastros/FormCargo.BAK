    *--------------------------------------------------------------------------
    * HabilitarCampos - Habilita/desabilita campos conforme modo
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE HabilitarCampos(par_lHabilitar)
        LOCAL loc_oPagina
        loc_oPagina = THIS.pgf_4c_Paginas.Page2

        *-- C�digo: s� habilitar no modo INCLUIR (PROBLEMA 19)
        IF THIS.this_cModoAtual = "INCLUIR"
            loc_oPagina.txt_4c_Codigo.Enabled = .T.
        ELSE
            loc_oPagina.txt_4c_Codigo.Enabled = .F.
        ENDIF

        *-- Demais campos: habilitar/desabilitar conforme par�metro
        loc_oPagina.txt_4c_Descricao.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LimDesconto.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_DescPercent.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LimAcrescimo.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_AcresPercent.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_VlLibPag.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_VlLibCot.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_VlLibOpe.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_VarCot.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_GrupoComis.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_Nivel.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_AltCot.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_Limite.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_CancItem.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibFpag.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibFpg.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibSdIns.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibOpe.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_FatComis.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_FatorComis.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_Comissao.Enabled = par_lHabilitar
        loc_oPagina.opt_4c_TipoComis.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibAltCli.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibExPrd.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibOpers.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibVarPeso.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibTroca.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibLeilao.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibDupEnd.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibSldTqe.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibDupTit.Enabled = par_lHabilitar
        loc_oPagina.txt_4c_LibPrze.Enabled = par_lHabilitar

        *-- Grid e bot�es do grid
        loc_oPagina.grd_4c_CentroCusto.Enabled = par_lHabilitar
        loc_oPagina.cmd_4c_InserirGrid.Enabled = par_lHabilitar
        loc_oPagina.cmd_4c_ExcluirGrid.Enabled = par_lHabilitar
    ENDPROC

    *--------------------------------------------------------------------------
    * AlternarPagina - Alterna entre p�ginas do PageFrame
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE AlternarPagina(par_nPagina)
        THIS.pgf_4c_Paginas.ActivePage = par_nPagina
    ENDPROC

    *--------------------------------------------------------------------------
    * PROBLEMA 17 e 18: BtnIncluirClick - Bot�o Incluir (PUBLIC sem PROTECTED)
    *--------------------------------------------------------------------------
    PROCEDURE BtnIncluirClick()
        THIS.this_oBusinessObject.NovoRegistro()  && PROBLEMA 18: Preparar INSERT
        THIS.LimparCampos()
        THIS.CriarCursorCentroCusto()              && Cria cursor vazio para novo registro
        THIS.this_cModoAtual = "INCLUIR"           && PROBLEMA 19: ANTES de HabilitarCampos
        THIS.HabilitarCampos(.T.)
        THIS.AlternarPagina(2)
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnVisualizarClick - Bot�o Visualizar (PUBLIC)
    *--------------------------------------------------------------------------
    PROCEDURE BtnVisualizarClick()
        LOCAL loc_cCodigo

        IF !USED("cursor_4c_Dados") OR RECCOUNT("cursor_4c_Dados") = 0
            MsgAviso("Nenhum registro selecionado!")
            RETURN
        ENDIF

        SELECT cursor_4c_Dados
        loc_cCodigo = ALLTRIM(cursor_4c_Dados.cods)

        IF THIS.this_oBusinessObject.CarregarPorCodigo(loc_cCodigo)
            THIS.BOParaForm()
            THIS.CarregarCentroCusto(loc_cCodigo)        && Carrega grid de centro de custo
            THIS.this_cModoAtual = "VISUALIZAR"
            THIS.HabilitarCampos(.F.)
            THIS.AlternarPagina(2)
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnAlterarClick - Bot�o Alterar (PUBLIC) - PROBLEMA 18
    *--------------------------------------------------------------------------
    PROCEDURE BtnAlterarClick()
        LOCAL loc_cCodigo

        IF !USED("cursor_4c_Dados") OR RECCOUNT("cursor_4c_Dados") = 0
            MsgAviso("Nenhum registro selecionado!")
            RETURN
        ENDIF

        SELECT cursor_4c_Dados
        loc_cCodigo = ALLTRIM(cursor_4c_Dados.cods)

        IF THIS.this_oBusinessObject.CarregarPorCodigo(loc_cCodigo)
            THIS.this_oBusinessObject.EditarRegistro()  && PROBLEMA 18: Preparar UPDATE
            THIS.BOParaForm()
            THIS.CarregarCentroCusto(loc_cCodigo)        && Carrega grid de centro de custo
            THIS.this_cModoAtual = "ALTERAR"             && PROBLEMA 19: ANTES de HabilitarCampos
            THIS.HabilitarCampos(.T.)
            THIS.AlternarPagina(2)
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnExcluirClick - Bot�o Excluir (PUBLIC)
    *--------------------------------------------------------------------------
    PROCEDURE BtnExcluirClick()
        LOCAL loc_cCodigo

        IF !USED("cursor_4c_Dados") OR RECCOUNT("cursor_4c_Dados") = 0
            MsgAviso("Nenhum registro selecionado!")
            RETURN
        ENDIF

        SELECT cursor_4c_Dados
        loc_cCodigo = ALLTRIM(cursor_4c_Dados.cods)

        IF MsgConfirma("Confirma exclus" + CHR(227) + "o do cargo " + loc_cCodigo + "?")
            IF THIS.this_oBusinessObject.CarregarPorCodigo(loc_cCodigo)
                IF THIS.this_oBusinessObject.Excluir()
                    MsgSucesso("Cargo exclu" + CHR(237) + "do com sucesso!")
                    THIS.CarregarLista()
                ENDIF
            ENDIF
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnBuscarClick - Bot�o Buscar (PUBLIC)
    *--------------------------------------------------------------------------
    PROCEDURE BtnBuscarClick()
        LOCAL loc_cFiltro
        loc_cFiltro = INPUTBOX("Digite o texto para buscar:", "Buscar Cargo")

        IF !EMPTY(loc_cFiltro)
            IF THIS.this_oBusinessObject.Buscar(loc_cFiltro)
                LOCAL loc_oGrid
                loc_oGrid = THIS.pgf_4c_Paginas.Page1.grd_4c_Lista
                loc_oGrid.RecordSource = "cursor_4c_Dados"
                loc_oGrid.Column1.ControlSource = "cursor_4c_Dados.cods"
                loc_oGrid.Column2.ControlSource = "cursor_4c_Dados.descs"
                loc_oGrid.Column1.Header1.Caption = "C" + CHR(243) + "digo"
                loc_oGrid.Column2.Header1.Caption = "Descri" + CHR(231) + CHR(227) + "o"
                THIS.FormatarGridLista(loc_oGrid)
            ENDIF
        ENDIF
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnEncerrarClick - Bot�o Encerrar (PUBLIC)
    *--------------------------------------------------------------------------
    PROCEDURE BtnEncerrarClick()
        THIS.Release()
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnSalvarClick - Bot�o Salvar (PUBLIC) - PROBLEMA 4 e 16
    *--------------------------------------------------------------------------
    PROCEDURE BtnSalvarClick()
        *-- PROBLEMA 16: Valida��es FORA do TRY
        IF EMPTY(ALLTRIM(THIS.pgf_4c_Paginas.Page2.txt_4c_Codigo.Value))
            MsgAviso("Campo C" + CHR(243) + "digo " + CHR(233) + " obrigat" + CHR(243) + "rio!")
            THIS.pgf_4c_Paginas.Page2.txt_4c_Codigo.SetFocus()
            RETURN
        ENDIF

        IF EMPTY(ALLTRIM(THIS.pgf_4c_Paginas.Page2.txt_4c_Descricao.Value))
            MsgAviso("Campo Descri" + CHR(231) + CHR(227) + "o " + CHR(233) + " obrigat" + CHR(243) + "rio!")
            THIS.pgf_4c_Paginas.Page2.txt_4c_Descricao.SetFocus()
            RETURN
        ENDIF

        TRY
            THIS.FormParaBO()

            *-- PROBLEMA 4: Salvar() SEM par�metro
            IF THIS.this_oBusinessObject.Salvar()
                *-- Salva tamb�m a subtabela de centro de custo
                IF !THIS.SalvarCentroCusto(THIS.this_oBusinessObject.this_cCodigo)
                    MsgErro("Cargo salvo, mas houve erro ao salvar centro de custo!")
                ELSE
                    MsgSucesso("Cargo salvo com sucesso!")
                ENDIF
                THIS.AlternarPagina(1)
                THIS.CarregarLista()  && PROBLEMA 2: Recarregar lista
            ENDIF

        CATCH TO loException
            MostrarErro("Erro ao salvar:" + CHR(13) + loException.Message, "Erro")
        ENDTRY
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnCancelarClick - Bot�o Cancelar (PUBLIC) - PROBLEMA 2
    *--------------------------------------------------------------------------
    PROCEDURE BtnCancelarClick()
        THIS.AlternarPagina(1)
        THIS.this_cModoAtual = "LISTA"
        THIS.CarregarLista()  && PROBLEMA 2: Recarregar lista
    ENDPROC

    *--------------------------------------------------------------------------
    * CriarCursorCentroCusto - Cria cursor local para edi��o do grid
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE CriarCursorCentroCusto()
        IF USED("cursor_4c_CCLocal")
            USE IN cursor_4c_CCLocal
        ENDIF

        CREATE CURSOR cursor_4c_CCLocal (;
            Grupos C(10), ;
            Contas C(20), ;
            Valors N(14,2), ;
            Moedas C(3))

        *-- Configura RecordSource do grid
        THIS.pgf_4c_Paginas.Page2.grd_4c_CentroCusto.RecordSource = "cursor_4c_CCLocal"
        THIS.ConfigurarGridCentroCusto()  && Reconfigura colunas ap�s RecordSource
    ENDPROC

    *--------------------------------------------------------------------------
    * CarregarCentroCusto - Carrega dados do banco para o cursor local
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE CarregarCentroCusto(par_cCodigo)
        LOCAL loc_cGrupo, loc_cConta, loc_nValor, loc_cMoeda

        THIS.CriarCursorCentroCusto()

        *-- Carrega dados da subtabela SigCrRcc
        IF THIS.this_oBusinessObject.CarregarCentroCusto(par_cCodigo)
            IF USED("cursor_4c_CCRemoto") AND RECCOUNT("cursor_4c_CCRemoto") > 0
                SELECT cursor_4c_CCRemoto
                GO TOP
                SCAN
                    *-- Captura valores ANTES de mudar de cursor
                    loc_cGrupo = ALLTRIM(cursor_4c_CCRemoto.grupos)
                    loc_cConta = ALLTRIM(cursor_4c_CCRemoto.contas)
                    loc_nValor = cursor_4c_CCRemoto.valors
                    loc_cMoeda = ALLTRIM(cursor_4c_CCRemoto.moedas)

                    *-- Insere no cursor local
                    INSERT INTO cursor_4c_CCLocal (Grupos, Contas, Valors, Moedas) ;
                        VALUES (loc_cGrupo, loc_cConta, loc_nValor, loc_cMoeda)
                ENDSCAN
                USE IN cursor_4c_CCRemoto
            ENDIF
        ENDIF

        SELECT cursor_4c_CCLocal
        IF RECCOUNT() = 0
            APPEND BLANK  && Linha em branco para edi��o
        ENDIF
        GO TOP
        THIS.pgf_4c_Paginas.Page2.grd_4c_CentroCusto.Refresh()
    ENDPROC

    *--------------------------------------------------------------------------
    * SalvarCentroCusto - Salva dados do cursor local para o banco (via BO)
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE SalvarCentroCusto(par_cCodigo)
        LOCAL loc_lResultado
        loc_lResultado = .F.

        IF !USED("cursor_4c_CCLocal")
            RETURN .T.  && Se cursor n�o existe, n�o h� nada para salvar
        ENDIF

        *-- Chama m�todo do BO para salvar subtabela
        loc_lResultado = THIS.this_oBusinessObject.SalvarCentroCusto(par_cCodigo, "cursor_4c_CCLocal")

        RETURN loc_lResultado
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnInserirGridClick - Bot�o Inserir linha no grid (PUBLIC)
    *--------------------------------------------------------------------------
    PROCEDURE BtnInserirGridClick()
        IF !USED("cursor_4c_CCLocal")
            THIS.CriarCursorCentroCusto()
        ENDIF

        SELECT cursor_4c_CCLocal
        APPEND BLANK
        THIS.pgf_4c_Paginas.Page2.grd_4c_CentroCusto.Refresh()
        THIS.pgf_4c_Paginas.Page2.grd_4c_CentroCusto.SetFocus()
    ENDPROC

    *--------------------------------------------------------------------------
    * BtnExcluirGridClick - Bot�o Excluir linha do grid (PUBLIC)
    *--------------------------------------------------------------------------
    PROCEDURE BtnExcluirGridClick()
        IF !USED("cursor_4c_CCLocal") OR RECCOUNT("cursor_4c_CCLocal") = 0
            MsgAviso("Nenhuma linha para excluir!")
            RETURN
        ENDIF

        IF MsgConfirma("Deseja excluir esta linha?")
            SELECT cursor_4c_CCLocal
            DELETE
            PACK

            IF RECCOUNT() = 0
                APPEND BLANK  && Adiciona linha em branco
            ENDIF

            GO TOP
            THIS.pgf_4c_Paginas.Page2.grd_4c_CentroCusto.Refresh()
        ENDIF
    ENDPROC

ENDDEFINE
