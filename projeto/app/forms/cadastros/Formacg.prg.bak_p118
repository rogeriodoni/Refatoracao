                        VALUES(loc_cIdChaves, ;
                        "Grupo : " + THIS.this_cGrupos + " Usuario : " + loc_cUsuario, "I")
                ELSE
                    IF crLogData.cTipos = "E"
                        DELETE
                    ENDIF
                ENDIF
            ENDIF
        NEXT

        loc_oPag1.obj_4c_Usuario.Clear()
    ENDPROC

