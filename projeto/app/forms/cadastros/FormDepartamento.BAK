*==============================================================================
* FORMDEPARTAMENTO.PRG
* Formulario de cadastro de departamentos
*
* Tabela: SigCdDpt
* Campos: codigos, descricaos, diretors, nchksubs, nchktipos, autos
*
* LOOKUPS IDENTIFICADOS:
* - Diretor: SigCdUsu (Usuarios/NComps) - Filtro: cAtivos <> 'N'
*
* REGRAS APLICADAS:
* - Nomenclatura: loc_ para locais, par_ para parametros, this_ para classe
* - Controles: tipo_4c_Nome (txt_4c_, cmd_4c_, grd_4c_, lbl_4c_, cnt_4c_, pgf_4c_)
* - ShowWindow = 1, WindowType = 1 para forms modais estaveis
* - PicturePosition = 13 para icone acima do texto em botoes
* - SEMPRE inicializar TextBox.Value (string="", numeric=0)
* - Usar cursor_4c_Dados como nome padrao de cursor
* - TornarControlesVisiveis percorre Pages E Controls
*==============================================================================

*------------------------------------------------------------------------------
* PageFrameDuasPaginas - PageFrame customizado com 2 paginas
*------------------------------------------------------------------------------
DEFINE CLASS PageFrameDuasPaginas AS PageFrame
    PageCount = 2
    BorderWidth = 0
    TabStyle = 0
ENDDEFINE

*------------------------------------------------------------------------------
* FormDepartamento - Formulario de cadastro de departamentos
*------------------------------------------------------------------------------
DEFINE CLASS FormDepartamento AS FormBase

    *-- Propriedades obrigatorias para forms modais
    DataSession = 2
    Height = 600
    Width = 1000
    Caption = "Cadastro de Departamentos"
    this_cTituloForm = "Cadastro de Departamentos"
    ShowWindow = 1
    WindowType = 1
    AutoCenter = .T.

    *-- Propriedades do frmcadastro (sem barra de titulo)
    TitleBar = 0
    ControlBox = .F.
    Closable = .F.
    MaxButton = .F.
    MinButton = .F.
    ClipControls = .F.
    Themes = .F.
    BorderStyle = 2

    *-- Propriedades customizadas
    this_cModoAtual = "LISTA"

    *-- PageFrame para alternar entre Lista e Dados
    ADD OBJECT pgf_4c_Principal AS PageFrameDuasPaginas

    *--------------------------------------------------------------------------
    * InicializarForm - Inicializacao especifica do formulario
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE InicializarForm()
        LOCAL loc_oException, loc_lSucesso

        loc_lSucesso = .F.

        TRY
            THIS.this_oBusinessObject = CREATEOBJECT("DepartamentoBO")

            IF ISNULL(THIS.this_oBusinessObject)
                MESSAGEBOX("Erro ao criar Business Object DepartamentoBO!", 16, "Erro")
                loc_lSucesso = .F.
            ELSE
                THIS.ConfigurarPageFrame()
                THIS.ConfigurarPaginaLista()
                THIS.ConfigurarPaginaDados()

                IF !THIS.CarregarLista()
                    * Se falhar ao carregar, nao impede abertura
                ENDIF

                THIS.pgf_4c_Principal.ActivePage = 1
                THIS.this_cModoAtual = "LISTA"
                loc_lSucesso = .T.
            ENDIF

        CATCH TO loc_oException
            MESSAGEBOX("Erro: " + loc_oException.Message, 16, "Erro")
            loc_lSucesso = .F.
        ENDTRY

        RETURN loc_lSucesso
    ENDPROC

    *--------------------------------------------------------------------------
    * ConfigurarPageFrame
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE ConfigurarPageFrame()
        WITH THIS.pgf_4c_Principal
            .Top = 0
            .Left = 0
            .Width = THIS.Width
            .Height = THIS.Height
            .Tabs = .F.
            .Page1.Caption = "Lista"
            .Page2.Caption = "Dados"
        ENDWITH
    ENDPROC

    *--------------------------------------------------------------------------
    * ConfigurarPaginaLista
    *--------------------------------------------------------------------------
    PROTECTED PROCEDURE ConfigurarPaginaLista()
        LOCAL loc_oPagina, loc_cIconPath
        loc_oPagina = THIS.pgf_4c_Principal.Page1
        loc_cIconPath = gc_4c_CaminhoIcones

        * Container do cabecalho
        loc_oPagina.AddObject("cnt_4c_Cabecalho", "Container")
        WITH loc_oPagina.cnt_4c_Cabecalho
            .Top = 0
            .Left = 0
            .Width = THIS.Width
            .Height = 90
            .BackColor = RGB(90, 90, 90)
            .BorderWidth = 0
        ENDWITH

        * Titulo
        loc_oPagina.cnt_4c_Cabecalho.AddObject("lbl_4c_Titulo", "Label")
        WITH loc_oPagina.cnt_4c_Cabecalho.lbl_4c_Titulo
            .Caption = "Departamentos"
            .FontName = "Tahoma"
            .FontSize = 16
            .FontBold = .T.
            .ForeColor = RGB(255, 255, 255)
            .BackStyle = 0
            .Left = 20
            .Top = 25
            .AutoSize = .T.
            .Visible = .T.
        ENDWITH

        * Container dos botoes - posicao conforme legado (Left=544)
        loc_oPagina.AddObject("cnt_4c_Botoes", "Container")
        WITH loc_oPagina.cnt_4c_Botoes
            .Top = 5
            .Left = 544
            .Width = 456
            .Height = 85
            .BackStyle = 0
            .BorderWidth = 0
        ENDWITH

        * Botao Incluir - 75x75, sem espacamento (Left = 5, 80, 155, 230, 305, 380)
        loc_oPagina.cnt_4c_Botoes.AddObject("cmd_4c_Incluir", "CommandButton")
        WITH loc_oPagina.cnt_4c_Botoes.cmd_4c_Incluir
            .Caption = "Incluir"
            .Left = 5
            .Top = 5
            .Width = 75
            .Height = 75
            .FontName = "Tahoma"
            .FontSize = 8
            .Themes = .F.
            .SpecialEffect = 0
            .BackColor = RGB(255, 255, 255)
            .ForeColor = RGB(90, 90, 90)
            .Picture = loc_cIconPath + "cadastro_inserir_26.jpg"
            .PicturePosition = 13
            .Visible = .T.
        ENDWITH

        * Botao Visualizar
        loc_oPagina.cnt_4c_Botoes.AddObject("cmd_4c_Visualizar", "CommandButton")
        WITH loc_oPagina.cnt_4c_Botoes.cmd_4c_Visualizar
            .Caption = "Visualizar"
            .Left = 80
            .Top = 5
            .Width = 75
            .Height = 75
            .FontName = "Tahoma"
            .FontSize = 8
            .Themes = .F.
            .SpecialEffect = 0
            .BackColor = RGB(255, 255, 255)
            .ForeColor = RGB(90, 90, 90)
            .Picture = loc_cIconPath + "cadastro_vizualizar_60.jpg"
            .PicturePosition = 13
            .Visible = .T.
        ENDWITH

        * Botao Alterar
        loc_oPagina.cnt_4c_Botoes.AddObject("cmd_4c_Alterar", "CommandButton")
        WITH loc_oPagina.cnt_4c_Botoes.cmd_4c_Alterar
            .Caption = "Alterar"
            .Left = 155
            .Top = 5
            .Width = 75
            .Height = 75
            .FontName = "Tahoma"
            .FontSize = 8
            .Themes = .F.
            .SpecialEffect = 0
            .BackColor = RGB(255, 255, 255)
            .ForeColor = RGB(90, 90, 90)
            .Picture = loc_cIconPath + "cadastro_alterar_60.jpg"
            .PicturePosition = 13
            .Visible = .T.
        ENDWITH

        * Botao Excluir
        loc_oPagina.cnt_4c_Botoes.AddObject("cmd_4c_Excluir", "CommandButton")
        WITH loc_oPagina.cnt_4c_Botoes.cmd_4c_Excluir
            .Caption = "Excluir"
            .Left = 230
            .Top = 5
            .Width = 75
            .Height = 75
            .FontName = "Tahoma"
            .FontSize = 8
            .Themes = .F.
            .SpecialEffect = 0
            .BackColor = RGB(255, 255, 255)
            .ForeColor = RGB(90, 90, 90)
            .Picture = loc_cIconPath + "cadastro_excluir_60.jpg"
            .PicturePosition = 13
            .Visible = .T.
        ENDWITH

        * Botao Buscar
        loc_oPagina.cnt_4c_Botoes.AddObject("cmd_4c_Buscar", "CommandButton")
        WITH loc_oPagina.cnt_4c_Botoes.cmd_4c_Buscar
            .Caption = "Buscar"
            .Left = 305
            .Top = 5
            .Width = 75
            .Height = 75
            .FontName = "Tahoma"
            .FontSize = 8
            .Themes = .F.
            .SpecialEffect = 0
            .BackColor = RGB(255, 255, 255)
            .ForeColor = RGB(90, 90, 90)
            .Picture = loc_cIconPath + "cadastro_procurar_60.jpg"
            .PicturePosition = 13
            .Visible = .T.
        ENDWITH

        * Botao Encerrar
        loc_oPagina.cnt_4c_Botoes.AddObject("cmd_4c_Encerrar", "CommandButton")
        WITH loc_oPagina.cnt_4c_Botoes.cmd_4c_Encerrar
            .Caption = "Encerrar"
            .Left = 380
            .Top = 5
            .Width = 75
            .Height = 75
            .FontName = "Tahoma"
            .FontSize = 8
            .Themes = .F.
            .SpecialEffect = 0
            .BackColor = RGB(255, 255, 255)
            .ForeColor = RGB(90, 90, 90)
