    Themes = .F.

    *-- Propriedades internas
    this_lProcessando = .F.

    *--------------------------------------------------------------------------
    * Init - Inicializa????o do formul??rio
    *--------------------------------------------------------------------------
    PROCEDURE Init()
        LOCAL loc_lSucesso
        loc_lSucesso = .F.

        TRY
            *-- Configura controles
            THIS.ConfigurarControles()

            *-- Inicializa valores
            THIS.LimparCampos()

            loc_lSucesso = .T.

        CATCH TO loException
            MostrarErro("Erro ao inicializar formul" + CHR(225) + "rio:" + CHR(13) + ;
                       loException.Message, "Erro Init")
        ENDTRY

        RETURN loc_lSucesso
    ENDPROC

