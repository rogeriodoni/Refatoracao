        ENDWITH

        THIS.cnt_4c_Aguarde.AddObject("lbl_4c_Aguarde2", "Label")
        WITH THIS.cnt_4c_Aguarde.lbl_4c_Aguarde2
            .AutoSize = .T.
            .FontBold = .T.
            .FontName = "Tahoma"
            .FontSize = 10
