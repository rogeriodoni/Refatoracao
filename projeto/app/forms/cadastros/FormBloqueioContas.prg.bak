        *-- Bot??o Encerrar
        THIS.AddObject("cmd_4c_Encerrar", "CommandButton")
        WITH THIS.cmd_4c_Encerrar
            .Top = 3
            .Left = 423
            .Height = 75
            .Width = 75
            .Picture = gc_4c_CaminhoIcones + "cadastro_sair_60.jpg"
            .Caption = "Encerrar"
            .PicturePosition = 13
            .FontName = "Tahoma"
            .FontSize = 8
