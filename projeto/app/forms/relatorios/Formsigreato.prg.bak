        ENDIF
        IF loc_oCnt.cmd_4c_BtnGradeS.Value = 1
            SELECT cursor_4c_OperacoesS
            REPLACE ALL SelImp WITH .T.
            GO TOP
        ELSE
            SELECT cursor_4c_OperacoesS
