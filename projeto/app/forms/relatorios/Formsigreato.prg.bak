        loc_oGrd.Column3.Header1.ForeColor  = RGB(90, 90, 90)
        loc_oGrd.Column3.Header1.Alignment  = 2

        *-- Botoes Marca/Desmarca para Saidas ------------------------------
        loc_oCnt.AddObject("cmd_4c_BtnGradeS", "CommandGroup")
        WITH loc_oCnt.cmd_4c_BtnGradeS
