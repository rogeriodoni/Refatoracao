    *--------------------------------------------------------------------------
    * AtualizarEstadoCamposDescricao - Controla ReadOnly/Enabled dos campos
    *   Descricao ReadOnly quando codigo preenchido (When do legado).
    *   DtCotacao habilitada somente quando Moeda preenchida (When do legado).
    *--------------------------------------------------------------------------
    PROCEDURE AtualizarEstadoCamposDescricao()
        LOCAL loc_oPg
        TRY
            loc_oPg = THIS.pgf_4c_Paginas.Page1
            loc_oPg.txt_4c_DsGrestoque.ReadOnly = !EMPTY(ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value))
            loc_oPg.txt_4c_DsEstoque.ReadOnly   = !EMPTY(ALLTRIM(loc_oPg.txt_4c_CdEstoque.Value))
            loc_oPg.txt_4c_DsUnidade.ReadOnly   = !EMPTY(ALLTRIM(loc_oPg.txt_4c_CdUnidade.Value))
            loc_oPg.txt_4c_DsMoeda.ReadOnly     = !EMPTY(ALLTRIM(loc_oPg.txt_4c_CdMoeda.Value))
            loc_oPg.txt_4c_DtCotacao.Enabled    = !EMPTY(ALLTRIM(loc_oPg.txt_4c_CdMoeda.Value))
        CATCH TO loc_oErro
            MsgErro(loc_oErro.Message, "Erro")
        ENDTRY
    ENDPROC

    *==========================================================================
    * INTERFACE FORMBASE - stubs e traducoes CRUD->REPORT
    *==========================================================================

    PROCEDURE AtualizarEstadoControles()
        RETURN
    ENDPROC

    PROCEDURE CarregarLista()
        LOCAL loc_oPg
        TRY
            loc_oPg = THIS.pgf_4c_Paginas.Page1
            IF VARTYPE(loc_oPg) = "O" AND PEMSTATUS(loc_oPg, "txt_4c_Data", 5)
                loc_oPg.txt_4c_Data.SetFocus()
            ENDIF
        CATCH TO loc_oErro
            MsgErro(loc_oErro.Message, "Erro")
        ENDTRY
        RETURN .T.
    ENDPROC

    PROTECTED PROCEDURE FormParaBO()
        THIS.FormParaRelatorio()
    ENDPROC

    PROTECTED PROCEDURE BOParaForm()
        LOCAL loc_oPg
        TRY
            IF VARTYPE(THIS.this_oRelatorio) != "O"
                RETURN
            ENDIF
            loc_oPg = THIS.pgf_4c_Paginas.Page1
            WITH THIS.this_oRelatorio
                loc_oPg.txt_4c_CdGrestoque.Value = .this_cCdGrestoque
                loc_oPg.txt_4c_DsGrestoque.Value = .this_cDsGrestoque
                loc_oPg.txt_4c_CdEstoque.Value   = .this_cCdEstoque
                loc_oPg.txt_4c_DsEstoque.Value   = .this_cDsEstoque
                loc_oPg.txt_4c_CdUnidade.Value   = .this_cGrupo
                loc_oPg.txt_4c_DsUnidade.Value   = .this_cGrupoDesc
                loc_oPg.txt_4c_Data.Value        = .this_dData
                loc_oPg.txt_4c_CdMoeda.Value     = .this_cMoeda
                loc_oPg.txt_4c_DsMoeda.Value     = .this_cMoedaDesc
                loc_oPg.txt_4c_DtCotacao.Value   = .this_dDtCotacao
                loc_oPg.opt_4c_ImpCotacao.Value  = .this_nDadosCotacao
                loc_oPg.opt_4c_FatorVenda.Value  = .this_nOpcFator
            ENDWITH
            THIS.AtualizarEstadoCamposDescricao()
        CATCH TO loc_oErro
            MsgErro(loc_oErro.Message, "Erro")
        ENDTRY
    ENDPROC

    PROCEDURE HabilitarCampos(par_lHabilitar)
        LOCAL loc_oPg, loc_lHab
        TRY
            IF PCOUNT() = 0
                loc_lHab = .T.
            ELSE
                loc_lHab = par_lHabilitar
            ENDIF
            loc_oPg = THIS.pgf_4c_Paginas.Page1
            loc_oPg.txt_4c_CdGrestoque.Enabled  = loc_lHab
            loc_oPg.txt_4c_CdEstoque.Enabled    = loc_lHab
            loc_oPg.txt_4c_CdUnidade.Enabled    = loc_lHab
            loc_oPg.txt_4c_Data.Enabled         = loc_lHab
            loc_oPg.txt_4c_CdMoeda.Enabled      = loc_lHab
            loc_oPg.opt_4c_ImpCotacao.Enabled   = loc_lHab
            loc_oPg.opt_4c_FatorVenda.Enabled   = loc_lHab
            IF loc_lHab
                THIS.AtualizarEstadoCamposDescricao()
            ELSE
                loc_oPg.txt_4c_DsGrestoque.Enabled = .F.
                loc_oPg.txt_4c_DsEstoque.Enabled   = .F.
                loc_oPg.txt_4c_DsUnidade.Enabled   = .F.
                loc_oPg.txt_4c_DsMoeda.Enabled     = .F.
                loc_oPg.txt_4c_DtCotacao.Enabled   = .F.
            ENDIF
        CATCH TO loc_oErro
            MsgErro(loc_oErro.Message, "Erro")
        ENDTRY
    ENDPROC

    PROCEDURE AjustarBotoesPorModo()
        TRY
            IF VARTYPE(THIS.cmg_4c_Botoes) = "O"
                THIS.cmg_4c_Botoes.Buttons(1).Enabled = .T.
                THIS.cmg_4c_Botoes.Buttons(2).Enabled = .T.
                THIS.cmg_4c_Botoes.Buttons(3).Enabled = .T.
                THIS.cmg_4c_Botoes.Buttons(4).Enabled = .T.
            ENDIF
        CATCH TO loc_oErro
            MsgErro(loc_oErro.Message, "Erro")
        ENDTRY
    ENDPROC

    PROCEDURE BtnBuscarClick()
        THIS.BtnVisualizarClick()
    ENDPROC

    PROCEDURE BtnEncerrarClick()
        THIS.BtnSairClick()
    ENDPROC

    PROCEDURE BtnSalvarClick()
        THIS.BtnImprimirClick()
    ENDPROC

    PROCEDURE BtnCancelarClick()
        LOCAL loc_oPg
        TRY
            THIS.LimparCampos()
            loc_oPg = THIS.pgf_4c_Paginas.Page1
            IF VARTYPE(loc_oPg) = "O" AND PEMSTATUS(loc_oPg, "txt_4c_Data", 5)
                loc_oPg.txt_4c_Data.SetFocus()
            ENDIF
        CATCH TO loc_oErro
            MsgErro(loc_oErro.Message, "Erro")
        ENDTRY
    ENDPROC

    *--------------------------------------------------------------------------
    * Destroy - Libera referencia ao BO
    *--------------------------------------------------------------------------
    PROCEDURE Destroy()
        IF VARTYPE(THIS.this_oRelatorio) = "O"
            THIS.this_oRelatorio = .NULL.
        ENDIF
        DODEFAULT()
    ENDPROC

ENDDEFINE
