    *==========================================================================
    * LOOKUP - GRUPO DE ESTOQUE (SigCdGcr: Codigos/Descrs)
    * Equivalente ao fAcessoContab do legado (modo C=por codigo, D=por descricao)
    * Ao trocar o Grupo, limpa o campo Conta (estoque) pois o filtro muda.
    *==========================================================================

    PROCEDURE AbrirBuscaCdGrEst()
        LOCAL loc_cValor, loc_oBusca, loc_oPg
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value)
        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, ;
            "SigCdGcr", "cursor_4c_BuscaGrEst", "Codigos", loc_cValor, ;
            "Grupo de Estoque", .F., .T., "")
        IF VARTYPE(loc_oBusca) = "O"
            IF loc_oBusca.this_lSelecionou AND loc_oBusca.this_lAchouRegistro
                loc_oPg.txt_4c_CdGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Codigos)
                loc_oPg.txt_4c_DsGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Descrs)
            ELSE
                IF !loc_oBusca.this_lAchouRegistro
                    loc_oBusca.mAddColuna("Codigos", "", "C" + CHR(243) + "digo")
                    loc_oBusca.mAddColuna("Descrs",  "", "Descri" + CHR(231) + CHR(227) + "o")
                    loc_oBusca.Show()
                    IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaGrEst")
                        loc_oPg.txt_4c_CdGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Codigos)
                        loc_oPg.txt_4c_DsGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Descrs)
                    ENDIF
                ENDIF
            ENDIF
            loc_oBusca.Release()
        ENDIF
        IF USED("cursor_4c_BuscaGrEst")
            USE IN cursor_4c_BuscaGrEst
        ENDIF
        loc_oPg.txt_4c_CdEstoque.Value = ""
        loc_oPg.txt_4c_DsEstoque.Value = ""
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    PROCEDURE AbrirBuscaDsGrEst()
        LOCAL loc_cValor, loc_oBusca, loc_oPg
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_DsGrestoque.Value)
        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, ;
            "SigCdGcr", "cursor_4c_BuscaGrEst", "Descrs", loc_cValor, ;
            "Grupo de Estoque", .F., .T., "")
        IF VARTYPE(loc_oBusca) = "O"
            IF loc_oBusca.this_lSelecionou AND loc_oBusca.this_lAchouRegistro
                loc_oPg.txt_4c_DsGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Descrs)
                loc_oPg.txt_4c_CdGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Codigos)
            ELSE
                IF !loc_oBusca.this_lAchouRegistro
                    loc_oBusca.mAddColuna("Descrs",  "", "Descri" + CHR(231) + CHR(227) + "o")
                    loc_oBusca.mAddColuna("Codigos", "", "C" + CHR(243) + "digo")
                    loc_oBusca.Show()
                    IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaGrEst")
                        loc_oPg.txt_4c_DsGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Descrs)
                        loc_oPg.txt_4c_CdGrestoque.Value = ALLTRIM(cursor_4c_BuscaGrEst.Codigos)
                    ENDIF
                ENDIF
            ENDIF
            loc_oBusca.Release()
        ENDIF
        IF USED("cursor_4c_BuscaGrEst")
            USE IN cursor_4c_BuscaGrEst
        ENDIF
        loc_oPg.txt_4c_CdEstoque.Value = ""
        loc_oPg.txt_4c_DsEstoque.Value = ""
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    PROTECTED PROCEDURE ValidarCdGrEst()
        LOCAL loc_cValor, loc_cSQL, loc_nResult, loc_oPg
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value)
        IF EMPTY(loc_cValor)
            loc_oPg.txt_4c_DsGrestoque.Value = ""
            loc_oPg.txt_4c_CdEstoque.Value   = ""
            loc_oPg.txt_4c_DsEstoque.Value   = ""
            THIS.AtualizarEstadoCamposDescricao()
            RETURN
        ENDIF
        loc_cSQL = "SELECT Codigos, Descrs FROM SigCdGcr" + ;
            " WHERE Codigos = " + EscaparSQL(loc_cValor)
        loc_nResult = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_GrEstVal")
        IF loc_nResult > 0
            SELECT cursor_4c_GrEstVal
            IF !EOF()
                loc_oPg.txt_4c_DsGrestoque.Value = ALLTRIM(cursor_4c_GrEstVal.Descrs)
            ELSE
                loc_oPg.txt_4c_DsGrestoque.Value = ""
                THIS.AbrirBuscaCdGrEst()
            ENDIF
        ELSE
            loc_oPg.txt_4c_DsGrestoque.Value = ""
            THIS.AbrirBuscaCdGrEst()
        ENDIF
        IF USED("cursor_4c_GrEstVal")
            USE IN cursor_4c_GrEstVal
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    PROTECTED PROCEDURE ValidarDsGrEst()
        LOCAL loc_cValor, loc_cSQL, loc_nResult, loc_oPg
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_DsGrestoque.Value)
        IF EMPTY(loc_cValor)
            loc_oPg.txt_4c_CdGrestoque.Value = ""
            loc_oPg.txt_4c_CdEstoque.Value   = ""
            loc_oPg.txt_4c_DsEstoque.Value   = ""
            THIS.AtualizarEstadoCamposDescricao()
            RETURN
        ENDIF
        loc_cSQL = "SELECT Codigos, Descrs FROM SigCdGcr" + ;
            " WHERE Descrs LIKE " + EscaparSQL(loc_cValor + "%")
        loc_nResult = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_GrEstVal2")
        IF loc_nResult > 0
            SELECT cursor_4c_GrEstVal2
            IF !EOF()
                loc_oPg.txt_4c_CdGrestoque.Value = ALLTRIM(cursor_4c_GrEstVal2.Codigos)
                loc_oPg.txt_4c_DsGrestoque.Value = ALLTRIM(cursor_4c_GrEstVal2.Descrs)
            ELSE
                THIS.AbrirBuscaDsGrEst()
            ENDIF
        ELSE
            THIS.AbrirBuscaDsGrEst()
        ENDIF
        IF USED("cursor_4c_GrEstVal2")
            USE IN cursor_4c_GrEstVal2
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    *==========================================================================
    * LOOKUP - ESTOQUE/CONTA (SigCdCli: iclis/rclis, filtrado por Grupo)
    * Equivalente ao fAcessoContas do legado (modo C=por codigo, D=por descricao)
    *==========================================================================

    PROCEDURE AbrirBuscaCdEstoque()
        LOCAL loc_cValor, loc_oBusca, loc_oPg, loc_cGrupo, loc_cWhere
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_CdEstoque.Value)
        loc_cGrupo = ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value)
        loc_cWhere = IIF(EMPTY(loc_cGrupo), "", "Grupos = " + EscaparSQL(loc_cGrupo))
        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, ;
            "SigCdCli", "cursor_4c_BuscaEstoque", "iclis", loc_cValor, ;
            "Sele" + CHR(231) + CHR(227) + "o de Estoque", ;
            .F., .T., loc_cWhere)
        IF VARTYPE(loc_oBusca) = "O"
            IF loc_oBusca.this_lSelecionou AND loc_oBusca.this_lAchouRegistro
                loc_oPg.txt_4c_CdEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.iclis)
                loc_oPg.txt_4c_DsEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.rclis)
            ELSE
                IF !loc_oBusca.this_lAchouRegistro
                    loc_oBusca.mAddColuna("iclis", "", "C" + CHR(243) + "digo")
                    loc_oBusca.mAddColuna("rclis", "", "Nome")
                    loc_oBusca.Show()
                    IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaEstoque")
                        loc_oPg.txt_4c_CdEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.iclis)
                        loc_oPg.txt_4c_DsEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.rclis)
                    ENDIF
                ENDIF
            ENDIF
            loc_oBusca.Release()
        ENDIF
        IF USED("cursor_4c_BuscaEstoque")
            USE IN cursor_4c_BuscaEstoque
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    PROCEDURE AbrirBuscaDsEstoque()
        LOCAL loc_cValor, loc_oBusca, loc_oPg, loc_cGrupo, loc_cWhere
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_DsEstoque.Value)
        loc_cGrupo = ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value)
        loc_cWhere = IIF(EMPTY(loc_cGrupo), "", "Grupos = " + EscaparSQL(loc_cGrupo))
        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, ;
            "SigCdCli", "cursor_4c_BuscaEstoque", "rclis", loc_cValor, ;
            "Sele" + CHR(231) + CHR(227) + "o de Estoque", ;
            .F., .T., loc_cWhere)
        IF VARTYPE(loc_oBusca) = "O"
            IF loc_oBusca.this_lSelecionou AND loc_oBusca.this_lAchouRegistro
                loc_oPg.txt_4c_DsEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.rclis)
                loc_oPg.txt_4c_CdEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.iclis)
            ELSE
                IF !loc_oBusca.this_lAchouRegistro
                    loc_oBusca.mAddColuna("rclis", "", "Nome")
                    loc_oBusca.mAddColuna("iclis", "", "C" + CHR(243) + "digo")
                    loc_oBusca.Show()
                    IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaEstoque")
                        loc_oPg.txt_4c_DsEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.rclis)
                        loc_oPg.txt_4c_CdEstoque.Value = ALLTRIM(cursor_4c_BuscaEstoque.iclis)
                    ENDIF
                ENDIF
            ENDIF
            loc_oBusca.Release()
        ENDIF
        IF USED("cursor_4c_BuscaEstoque")
            USE IN cursor_4c_BuscaEstoque
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    PROTECTED PROCEDURE ValidarCdEstoque()
        LOCAL loc_cValor, loc_cSQL, loc_nResult, loc_oPg, loc_cGrupo
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_CdEstoque.Value)
        loc_cGrupo = ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value)
        IF EMPTY(loc_cValor)
            loc_oPg.txt_4c_DsEstoque.Value = ""
            THIS.AtualizarEstadoCamposDescricao()
            RETURN
        ENDIF
        loc_cSQL = "SELECT iclis, rclis FROM SigCdCli WHERE iclis = " + ;
            EscaparSQL(loc_cValor)
        IF !EMPTY(loc_cGrupo)
            loc_cSQL = loc_cSQL + " AND Grupos = " + EscaparSQL(loc_cGrupo)
        ENDIF
        loc_nResult = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_EstVal")
        IF loc_nResult > 0
            SELECT cursor_4c_EstVal
            IF !EOF()
                loc_oPg.txt_4c_DsEstoque.Value = ALLTRIM(cursor_4c_EstVal.rclis)
            ELSE
                loc_oPg.txt_4c_DsEstoque.Value = ""
                THIS.AbrirBuscaCdEstoque()
            ENDIF
        ELSE
            loc_oPg.txt_4c_DsEstoque.Value = ""
            THIS.AbrirBuscaCdEstoque()
        ENDIF
        IF USED("cursor_4c_EstVal")
            USE IN cursor_4c_EstVal
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    PROTECTED PROCEDURE ValidarDsEstoque()
        LOCAL loc_cValor, loc_cSQL, loc_nResult, loc_oPg, loc_cGrupo
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_DsEstoque.Value)
        loc_cGrupo = ALLTRIM(loc_oPg.txt_4c_CdGrestoque.Value)
        IF EMPTY(loc_cValor)
            loc_oPg.txt_4c_CdEstoque.Value = ""
            THIS.AtualizarEstadoCamposDescricao()
            RETURN
        ENDIF
        loc_cSQL = "SELECT iclis, rclis FROM SigCdCli WHERE rclis LIKE " + ;
            EscaparSQL(loc_cValor + "%")
        IF !EMPTY(loc_cGrupo)
            loc_cSQL = loc_cSQL + " AND Grupos = " + EscaparSQL(loc_cGrupo)
        ENDIF
        loc_nResult = SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_EstVal2")
        IF loc_nResult > 0
            SELECT cursor_4c_EstVal2
            IF !EOF()
                loc_oPg.txt_4c_CdEstoque.Value = ALLTRIM(cursor_4c_EstVal2.iclis)
                loc_oPg.txt_4c_DsEstoque.Value = ALLTRIM(cursor_4c_EstVal2.rclis)
            ELSE
                THIS.AbrirBuscaDsEstoque()
            ENDIF
        ELSE
            THIS.AbrirBuscaDsEstoque()
        ENDIF
        IF USED("cursor_4c_EstVal2")
            USE IN cursor_4c_EstVal2
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

    *==========================================================================
    * LOOKUP - UNIDADE (SigCdUni: cunis/dunis)
    * Equivalente ao fwbuscaext em 'SigCdUni'/'CrUnidades' do legado
    *==========================================================================

    PROCEDURE AbrirBuscaCdUnidade()
        LOCAL loc_cValor, loc_oBusca, loc_oPg
        loc_oPg    = THIS.pgf_4c_Paginas.Page1
        loc_cValor = ALLTRIM(loc_oPg.txt_4c_CdUnidade.Value)
        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, ;
            "SigCdUni", "cursor_4c_BuscaUnid", "cunis", loc_cValor, ;
            "Unidades", .F., .T., "")
        IF VARTYPE(loc_oBusca) = "O"
            IF loc_oBusca.this_lSelecionou AND loc_oBusca.this_lAchouRegistro
                loc_oPg.txt_4c_CdUnidade.Value = ALLTRIM(cursor_4c_BuscaUnid.cunis)
                loc_oPg.txt_4c_DsUnidade.Value = ALLTRIM(cursor_4c_BuscaUnid.dunis)
            ELSE
                IF !loc_oBusca.this_lAchouRegistro
                    loc_oBusca.mAddColuna("cunis", "", "C" + CHR(243) + "digo")
                    loc_oBusca.mAddColuna("dunis", "", "Descri" + CHR(231) + CHR(227) + "o")
                    loc_oBusca.Show()
                    IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaUnid")
                        loc_oPg.txt_4c_CdUnidade.Value = ALLTRIM(cursor_4c_BuscaUnid.cunis)
                        loc_oPg.txt_4c_DsUnidade.Value = ALLTRIM(cursor_4c_BuscaUnid.dunis)
                    ENDIF
                ENDIF
            ENDIF
            loc_oBusca.Release()
        ENDIF
        IF USED("cursor_4c_BuscaUnid")
            USE IN cursor_4c_BuscaUnid
        ENDIF
        THIS.AtualizarEstadoCamposDescricao()
    ENDPROC

