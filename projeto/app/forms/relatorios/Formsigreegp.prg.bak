                loc_oPagina.txt_4c__moeda_desc.Value = ALLTRIM(cursor_4c_SigCdMoe.dmoes)
            ELSE
                *-- MsgAviso + clear-field removidos (Pattern #114): abrir picker direto preserva valor digitado para LIKE prefix
                THIS.AbrirBuscaMoeda()
