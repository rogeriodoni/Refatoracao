    PROCEDURE ValidarCdMoeda()
        LOCAL loc_cCodigo, loc_oPagina
        TRY
            loc_oPagina = THIS.pgf_4c_Paginas.Page1
            loc_cCodigo = ALLTRIM(loc_oPagina.txt_4c__moeda.Value)
            IF EMPTY(loc_cCodigo)
                loc_oPagina.txt_4c__moeda_desc.Value = ""
