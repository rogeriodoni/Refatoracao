    PROCEDURE GridChkGrupoMouseUp
        LPARAMETERS par_nButton, par_nShift, par_nXCoord, par_nYCoord
        THIS.GridChkGrupoKeyPress(13, 0)
        NODEFAULT
    ENDPROC

    PROCEDURE GridChkGrupoMouseDown
        LPARAMETERS par_nButton, par_nShift, par_nXCoord, par_nYCoord
