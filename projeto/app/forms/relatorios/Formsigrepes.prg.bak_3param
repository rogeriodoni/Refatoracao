    ENDPROC

    *-- Subgrupo grid checkbox
    PROCEDURE GridChkSubgrupoKeyPress
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF INLIST(par_nKeyCode, 13, 32)
            REPLACE CrSubGrupo.nMarcas WITH IIF(CrSubGrupo.nMarcas == 0, 1, 0)
            THIS.pgf_4c_Paginas.Page2.grd_4c_Subgrupo.Refresh
            THIS.pgf_4c_Paginas.Page1.txt_4c_CdSubgrupo.Value = " "
            THIS.pgf_4c_Paginas.Page1.txt_4c_DsSubgrupo.Value = " "
            THIS.pgf_4c_Paginas.Page1.Refresh
            NODEFAULT
        ENDIF
    ENDPROC

    PROCEDURE GridChkSubgrupoClick
        NODEFAULT
    ENDPROC

