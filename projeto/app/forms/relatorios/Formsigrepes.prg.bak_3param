    *==========================================================================
    * CONFIGURARPAGEFRAME - PageFrame com 2 paginas
    * Original: Top=135, Left=-1, Width=1004, Height=472, PageCount=2
    *==========================================================================
    PROTECTED PROCEDURE ConfigurarPageFrame
        LOCAL loc_oPgf

        THIS.AddObject("pgf_4c_Paginas", "PageFrame")
        loc_oPgf = THIS.pgf_4c_Paginas

        *-- PageCount OBRIGATORIAMENTE ANTES de acessar Page1/Page2
        loc_oPgf.PageCount = 2

        loc_oPgf.Top    = 135
        loc_oPgf.Left   = -1
        loc_oPgf.Width  = 1004
        loc_oPgf.Height = 472

        *-- Configurar Page1 - FORA de qualquer WITH
        loc_oPgf.Page1.FontName  = "Tahoma"
        loc_oPgf.Page1.FontSize  = 8
        loc_oPgf.Page1.Caption   = "Filtros Principais"
        loc_oPgf.Page1.Picture   = gc_4c_CaminhoIcones + "fundo_cad_1003.jpg"
        loc_oPgf.Page1.BackColor = RGB(255, 255, 255)
        loc_oPgf.Page1.ForeColor = RGB(90, 90, 90)

        *-- Configurar Page2 - FORA de qualquer WITH
        loc_oPgf.Page2.FontName  = "Tahoma"
        loc_oPgf.Page2.FontSize  = 8
        loc_oPgf.Page2.Caption   = "Filtros M" + CHR(250) + "ltiplos"
        loc_oPgf.Page2.Picture   = gc_4c_CaminhoIcones + "fundo_cad_1003.jpg"
        loc_oPgf.Page2.BackColor = RGB(255, 255, 255)
        loc_oPgf.Page2.ForeColor = RGB(90, 90, 90)

        loc_oPgf.Visible = .T.

        THIS.ConfigurarPage1()
        THIS.ConfigurarPage2()
    ENDPROC

