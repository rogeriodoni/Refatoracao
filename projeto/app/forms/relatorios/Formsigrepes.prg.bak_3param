            IF !fAcessoContas(gc_4c_UsuarioLogado, loc_cGrupo, "D", loc_oP1.txt_4c_DContaVen.Value, ;
                    loc_oP1.txt_4c_ContaVen, loc_oP1.txt_4c_DContaVen)
                =MsgAviso("Acesso Negado !!!")
                loc_oP1.txt_4c_DContaVen.Value = ""
                loc_oP1.txt_4c_DContaVen.Refresh
            ENDIF
        ELSE
            loc_oP1.txt_4c_ContaVen.Value = ""
            loc_oP1.txt_4c_ContaVen.Refresh
        ENDIF
    ENDPROC

