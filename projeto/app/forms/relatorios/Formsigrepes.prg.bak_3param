    *-- OrigMerc grid checkbox
    PROCEDURE GridChkOrigMercKeyPress
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF INLIST(par_nKeyCode, 13, 32)
            REPLACE CrOrigMerc.nMarcas WITH IIF(CrOrigMerc.nMarcas == 0, 1, 0)
            THIS.pgf_4c_Paginas.Page1.grd_4c_OrigMerc.Refresh
            THIS.pgf_4c_Paginas.Page1.txt_4c_CdGrupoProd.Value = ""
            THIS.pgf_4c_Paginas.Page1.txt_4c_DsGrupoProd.Value = ""
            THIS.pgf_4c_Paginas.Page1.Refresh
            NODEFAULT
        ENDIF
    ENDPROC

    PROCEDURE GridChkOrigMercMouseUp
        LPARAMETERS par_nButton, par_nShift, par_nXCoord, par_nYCoord
        THIS.GridChkOrigMercKeyPress(13, 0)
        NODEFAULT
    ENDPROC

    PROCEDURE GridChkOrigMercMouseDown
        LPARAMETERS par_nButton, par_nShift, par_nXCoord, par_nYCoord
        NODEFAULT
    ENDPROC

