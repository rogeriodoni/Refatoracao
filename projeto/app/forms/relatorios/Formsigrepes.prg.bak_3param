    ENDPROC

    PROCEDURE ValidarRefFornecedor
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1, loc_cVal, loc_oBusca, loc_lForcarPicker, loc_cSQL
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        loc_cVal = ALLTRIM(loc_oP1.txt_4c_RefFornecedor.Value)
        loc_lForcarPicker = (par_nKeyCode = 115)

        IF EMPTY(loc_cVal) AND !loc_lForcarPicker
            RETURN
        ENDIF

        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar", gnConnHandle, "SigCdPro", ;
            "cursor_4c_BuscaRef", "Reffs", loc_cVal, "Refer" + CHR(234) + "ncias Fornecedor", .T.)
        IF VARTYPE(loc_oBusca) != "O"
            RETURN
        ENDIF

        IF loc_oBusca.this_lSelecionou AND loc_oBusca.this_lAchouRegistro AND !loc_lForcarPicker
            IF USED("cursor_4c_BuscaRef")
                loc_oP1.txt_4c_RefFornecedor.Value = ALLTRIM(cursor_4c_BuscaRef.Reffs)
            ENDIF
        ELSE
            IF USED("cursor_4c_BuscaRef")
                USE IN cursor_4c_BuscaRef
            ENDIF
            IF EMPTY(loc_cVal)
                loc_cSQL = "SELECT TOP 300 * FROM SigCdPro WHERE Reffs <> '' ORDER BY Reffs"
            ELSE
                loc_cSQL = "SELECT TOP 300 * FROM SigCdPro WHERE CAST(Reffs AS VARCHAR(50)) LIKE " + ;
                    EscaparSQL(loc_cVal + "%") + " ORDER BY Reffs"
            ENDIF
            IF SQLEXEC(gnConnHandle, loc_cSQL, "cursor_4c_BuscaRef") < 1 OR RECCOUNT("cursor_4c_BuscaRef") = 0
                IF USED("cursor_4c_BuscaRef")
                    USE IN cursor_4c_BuscaRef
                ENDIF
                =SQLEXEC(gnConnHandle, "SELECT TOP 300 * FROM SigCdPro WHERE Reffs <> '' ORDER BY Reffs", "cursor_4c_BuscaRef")
            ENDIF
            loc_oBusca.mAddColuna("Reffs", "", "Refer" + CHR(234) + "ncia")
            loc_oBusca.mAddColuna("CPros", "", "C" + CHR(243) + "digo")
            loc_oBusca.mAddColuna("DPros", "", "Descri" + CHR(231) + CHR(227) + "o")
            loc_oBusca.Show()
            IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaRef")
                loc_oP1.txt_4c_RefFornecedor.Value = ALLTRIM(cursor_4c_BuscaRef.Reffs)
            ENDIF
        ENDIF
        loc_oBusca.Release()
        IF USED("cursor_4c_BuscaRef")
            USE IN cursor_4c_BuscaRef
        ENDIF
        loc_oP1.txt_4c_RefFornecedor.Refresh
    ENDPROC

    PROCEDURE ValidarDopes
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        IF !USED("CrSigCdOpe")
            RETURN
        ENDIF

        LOCAL loc_cVal, loc_oBusca, loc_lForcarPicker
        loc_cVal = ALLTRIM(THIS.txt_4c_Dopes.Value)
        loc_lForcarPicker = (par_nKeyCode = 115)

        *-- Match exato em Enter/Tab: se encontrar, mantem valor sem abrir picker
        IF !EMPTY(loc_cVal) AND !loc_lForcarPicker
            SELECT CrSigCdOpe
            SET ORDER TO Dopes
            IF SEEK(loc_cVal)
                THIS.txt_4c_Dopes.Value = CrSigCdOpe.Dopes
                THIS.txt_4c_Dopes.Refresh
                RETURN
            ENDIF
        ENDIF

        *-- Popular cursor de picker a partir do cursor in-memory (CrSigCdOpe)
        IF USED("cursor_4c_BuscaOpe")
            USE IN cursor_4c_BuscaOpe
        ENDIF
        IF EMPTY(loc_cVal)
            SELECT Dopes FROM CrSigCdOpe ORDER BY Dopes INTO CURSOR cursor_4c_BuscaOpe READWRITE
        ELSE
            SELECT Dopes FROM CrSigCdOpe WHERE UPPER(ALLTRIM(Dopes)) LIKE UPPER(ALLTRIM(loc_cVal)) + "%" ;
                ORDER BY Dopes INTO CURSOR cursor_4c_BuscaOpe READWRITE
            IF RECCOUNT("cursor_4c_BuscaOpe") = 0
                USE IN cursor_4c_BuscaOpe
                SELECT Dopes FROM CrSigCdOpe ORDER BY Dopes INTO CURSOR cursor_4c_BuscaOpe READWRITE
            ENDIF
        ENDIF

        loc_oBusca = CREATEOBJECT("FormBuscaAuxiliar")
        IF VARTYPE(loc_oBusca) != "O"
            IF USED("cursor_4c_BuscaOpe")
                USE IN cursor_4c_BuscaOpe
            ENDIF
            RETURN
        ENDIF
        loc_oBusca.this_cTabela = ""
        loc_oBusca.this_cCursorDestino = "cursor_4c_BuscaOpe"
        loc_oBusca.this_cCampoBusca = "Dopes"
        loc_oBusca.this_cValorBusca = loc_cVal
        loc_oBusca.this_cTitulo = "Cadastro de Opera" + CHR(231) + CHR(227) + "o de Estoque"
        loc_oBusca.mAddColuna("Dopes", "", "Opera" + CHR(231) + CHR(227) + "o")
        loc_oBusca.Show()
        IF loc_oBusca.this_lSelecionou AND USED("cursor_4c_BuscaOpe")
            THIS.txt_4c_Dopes.Value = ALLTRIM(cursor_4c_BuscaOpe.Dopes)
        ENDIF
        loc_oBusca.Release()
        IF USED("cursor_4c_BuscaOpe")
            USE IN cursor_4c_BuscaOpe
        ENDIF
        THIS.txt_4c_Dopes.Refresh
    ENDPROC

    *==========================================================================
    * GRID CHECKBOX HANDLERS
