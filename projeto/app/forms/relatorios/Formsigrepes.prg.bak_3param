    PROCEDURE ValidarDsEmpresa
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        THIS.AbrirLookup(loc_oP1.txt_4c_CdEmpresa, loc_oP1.txt_4c_DsEmpresa, ;
            "SigCdEmp", "Cemps", "Razas", "Razas", loc_oP1.txt_4c_DsEmpresa.Value, ;
            "cursor_4c_BuscaEmpD", "Sele" + CHR(231) + CHR(227) + "o de Empresa", "", ;
            par_nKeyCode = 115)
    ENDPROC

    PROCEDURE ValidarDsGrpEstoque
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF !EMPTY(loc_oP1.txt_4c_DsGrpEstoque.Value)
            =fAcessoContab(gc_4c_UsuarioLogado, "D", loc_oP1.txt_4c_DsGrpEstoque.Value, ;
                loc_oP1.txt_4c_CdGrpEstoque, loc_oP1.txt_4c_DsGrpEstoque)
        ELSE
            loc_oP1.txt_4c_CdGrpEstoque.Value = ""
            loc_oP1.txt_4c_CdGrpEstoque.Refresh
        ENDIF
    ENDPROC

    PROCEDURE ValidarDsEstoque
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1, loc_cGrupo
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        loc_cGrupo = loc_oP1.txt_4c_CdGrpEstoque.Value
        IF !EMPTY(loc_oP1.txt_4c_DsEstoque.Value)
            IF !fAcessoContas(gc_4c_UsuarioLogado, loc_cGrupo, "D", loc_oP1.txt_4c_DsEstoque.Value, ;
                    loc_oP1.txt_4c_CdEstoque, loc_oP1.txt_4c_DsEstoque)
                =MsgAviso("Acesso Negado !!")
                loc_oP1.txt_4c_DsEstoque.Value = ""
                loc_oP1.txt_4c_DsEstoque.Refresh
                loc_oP1.txt_4c_CdEstoque.Value = ""
                loc_oP1.txt_4c_CdEstoque.Refresh
            ENDIF
        ELSE
            loc_oP1.txt_4c_CdEstoque.Value = ""
            loc_oP1.txt_4c_CdEstoque.Refresh
        ENDIF
    ENDPROC

    PROCEDURE ValidarDFornecedor
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF !EMPTY(loc_oP1.txt_4c_DFornecedor.Value)
            IF !fAcessoContas(gc_4c_UsuarioLogado, [], "D", loc_oP1.txt_4c_DFornecedor.Value, ;
                    loc_oP1.txt_4c_CFornecedor, loc_oP1.txt_4c_DFornecedor)
                =MsgAviso("Acesso Negado...")
                loc_oP1.txt_4c_DFornecedor.Value = ""
                loc_oP1.txt_4c_CFornecedor.Value = ""
            ENDIF
        ELSE
            loc_oP1.txt_4c_CFornecedor.Value = ""
            loc_oP1.txt_4c_DFornecedor.Value = ""
        ENDIF
        loc_oP1.txt_4c_CFornecedor.Refresh
        loc_oP1.txt_4c_DFornecedor.Refresh
    ENDPROC

    PROCEDURE ValidarDContaVen
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
