    *==========================================================================
    * AFTERROWCOLCHANGE - Grid Grupo -> filtra SubGrupo
    *==========================================================================
    PROCEDURE AfterRowColChangeGrupo
        LPARAMETERS par_nColIndex
        IF USED("CrSubGrupo") AND USED("CrGrupo")
            SELECT CrSubGrupo
            SET KEY TO CrGrupo.Grupos
            GO TOP
            THIS.pgf_4c_Paginas.Page2.grd_4c_Subgrupo.Refresh
            SELECT CrGrupo
        ENDIF
    ENDPROC

    *==========================================================================
    * DESTROY
    *==========================================================================
    PROCEDURE Destroy
        *-- Liberar cursores placeholder
        IF USED("cursor_4c_OrigMerc")
            USE IN cursor_4c_OrigMerc
        ENDIF
        IF USED("cursor_4c_TipoInvs")
            USE IN cursor_4c_TipoInvs
        ENDIF
        IF USED("cursor_4c_Grupo")
            USE IN cursor_4c_Grupo
        ENDIF
        IF USED("cursor_4c_Subgrupo")
            USE IN cursor_4c_Subgrupo
        ENDIF
        IF USED("cursor_4c_Linha")
            USE IN cursor_4c_Linha
        ENDIF
        IF USED("cursor_4c_SitTrib")
            USE IN cursor_4c_SitTrib
        ENDIF
        IF USED("cursor_4c_Cor")
            USE IN cursor_4c_Cor
        ENDIF
        IF USED("cursor_4c_GrpVenda")
            USE IN cursor_4c_GrpVenda
        ENDIF
        IF USED("cursor_4c_ClasFis")
            USE IN cursor_4c_ClasFis
        ENDIF
        IF USED("cursor_4c_RefFor")
            USE IN cursor_4c_RefFor
        ENDIF

        *-- Liberar cursores de referencia (carregados no Init)
        IF USED("CrSigCdEmp")
            USE IN CrSigCdEmp
        ENDIF
        IF USED("CrSigCdPam")
            USE IN CrSigCdPam
        ENDIF
        IF USED("CrSigCdPac")
            USE IN CrSigCdPac
        ENDIF
        IF USED("CrSigCdMoe")
            USE IN CrSigCdMoe
        ENDIF
        IF USED("CrSigCdCot")
            USE IN CrSigCdCot
        ENDIF
        IF USED("TmpMoe")
            USE IN TmpMoe
        ENDIF
        IF USED("CrSigCdUni")
            USE IN CrSigCdUni
        ENDIF
        IF USED("CrSigCdOpe")
            USE IN CrSigCdOpe
        ENDIF

        *-- Liberar cursores de filtro (carregados no MCursor)
        IF USED("CrOrigMerc")
            USE IN CrOrigMerc
        ENDIF
        IF USED("CrGrupo")
            USE IN CrGrupo
        ENDIF
        IF USED("CrSubGrupo")
            USE IN CrSubGrupo
        ENDIF
        IF USED("CrLinha")
            USE IN CrLinha
        ENDIF
        IF USED("CrRefFor")
            USE IN CrRefFor
        ENDIF
        IF USED("CrGrpVenda")
            USE IN CrGrpVenda
        ENDIF
        IF USED("CrSitTrib")
            USE IN CrSitTrib
        ENDIF
        IF USED("CrSigCdCor")
            USE IN CrSigCdCor
        ENDIF
        IF USED("CrClasFis")
            USE IN CrClasFis
        ENDIF
        IF USED("CrTipoInvs")
            USE IN CrTipoInvs
        ENDIF

        *-- Liberar cursores de processamento
        IF USED("CrSigMvEst")
            USE IN CrSigMvEst
        ENDIF
        IF USED("CsTemporario")
            USE IN CsTemporario
        ENDIF
        IF USED("CsTemporarioTEMP")
            USE IN CsTemporarioTEMP
        ENDIF
        IF USED("CrProdutos")
            USE IN CrProdutos
        ENDIF
        IF USED("TmpGrupo")
            USE IN TmpGrupo
        ENDIF
        IF USED("TmpGer")
            USE IN TmpGer
        ENDIF
        IF USED("crDet48c")
            USE IN crDet48c
        ENDIF
        IF USED("crExcel")
            USE IN crExcel
        ENDIF
        IF USED("CrBranco")
            USE IN CrBranco
        ENDIF

        *-- Liberar BO
        THIS.this_oBusinessObject = .NULL.

        DODEFAULT()
    ENDPROC

ENDDEFINE
