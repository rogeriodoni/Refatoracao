            .FontSize        = 8
            .Picture         = gc_4c_CaminhoIcones + "geral_envelope_32.jpg"
            .PicturePosition = 13
            .Themes          = .F.
            .BackColor       = RGB(255, 255, 255)
            .ForeColor       = RGB(90, 90, 90)
            .Visible         = .T.
        ENDWITH

        *-- Botao Encerrar - Left=206 (gap 2 apos Arquivos Email), cabe em CommandGroup Width=273
