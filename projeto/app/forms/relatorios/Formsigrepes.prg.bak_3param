            .Left            = 206
            .Width          = 65
            .Height         = 70
            .Caption         = "Encerrar"
            .WordWrap        = .T.
            .FontName       = "Comic Sans MS"
            .FontBold       = .T.
            .FontItalic     = .T.
            .FontSize        = 8
            .Picture         = gc_4c_CaminhoIcones + "relatorio_sair_60.jpg"
            .PicturePosition = 13
            .Themes          = .F.
            .BackColor       = RGB(255, 255, 255)
            .ForeColor       = RGB(90, 90, 90)
            .Visible         = .T.
        ENDWITH
    ENDPROC

