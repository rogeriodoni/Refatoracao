    *==========================================================================
    * INTERACTIVECHANGE HANDLERS
    *==========================================================================

    PROCEDURE InteractiveChangeOptObs
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF (loc_oP1.obj_4c_OptAgrupar.Value <> 1) AND (loc_oP1.obj_4c_OptTipImps.Value = 2)
            loc_oP1.obj_4c_OptAgrupar.Value = 1
            loc_oP1.obj_4c_OptAgrupar.Refresh
        ENDIF
    ENDPROC

    PROCEDURE InteractiveChangeOptTipImps
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF (loc_oP1.obj_4c_OptTipImps.Value = 2)
            loc_oP1.obj_4c_ChkImpImg.Value  = 1
            loc_oP1.obj_4c_OptAgrupar.Value = 1
            IF (loc_oP1.chk_4c_Custo.Value + loc_oP1.chk_4c_PreCusto.Value + ;
                loc_oP1.chk_4c_CMedio.Value + loc_oP1.chk_4c_CMedioF.Value = 0)
                loc_oP1.chk_4c_CMedioF.Value = 1
            ENDIF
        ENDIF
    ENDPROC

    PROCEDURE InteractiveChangeCmbOrdem
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF (loc_oP1.cmb_4c_Ordem.Value = 2)
            loc_oP1.chk_4c_Reffs.Value = 1
            loc_oP1.chk_4c_Reffs.Refresh
            loc_oP1.chk_4c_SubGrp.Value = 0
            loc_oP1.chk_4c_SubGrp.Refresh
        ENDIF
    ENDPROC

    PROCEDURE InteractiveChangeOptAgrupar
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF (NOT INLIST(loc_oP1.obj_4c_OptAgrupar.Value, 1, 4)) AND (loc_oP1.obj_4c_OptTipImps.Value = 2)
            loc_oP1.obj_4c_OptAgrupar.Value = 1
            loc_oP1.obj_4c_OptAgrupar.Refresh
        ENDIF
    ENDPROC

    PROCEDURE InteractiveChangeOptRfEstoque
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        loc_oP1.txt_4c_DataSaldo.Enabled = (loc_oP1.obj_4c_OptRfEstoque.Value = 2)
        loc_oP1.txt_4c_DataSaldo.Refresh
    ENDPROC

    PROCEDURE InteractiveChangeChkImpImg
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF (loc_oP1.obj_4c_ChkImpImg.Value = 2) AND (loc_oP1.obj_4c_OptTipImps.Value <> 1)
            loc_oP1.obj_4c_ChkImpImg.Value = 1
            loc_oP1.obj_4c_ChkImpImg.Refresh
        ENDIF
    ENDPROC

    PROCEDURE InteractiveChangePmedio
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF (loc_oP1.obj_4c_OptAgrupar.Value <> 1) AND (loc_oP1.obj_4c_OptTipImps.Value = 2)
            loc_oP1.obj_4c_OptAgrupar.Value = 1
            loc_oP1.obj_4c_OptAgrupar.Refresh
        ENDIF
    ENDPROC

    PROCEDURE InteractiveChangeOptPosEstoq
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
