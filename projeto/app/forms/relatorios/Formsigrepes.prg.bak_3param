    PROCEDURE ValidarGrupoProduto
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        THIS.AbrirLookup(loc_oP1.txt_4c_CdGrupoProd, loc_oP1.txt_4c_DsGrupoProd, ;
            "SigCdGrp", "CGrus", "DGrus", "CGrus", loc_oP1.txt_4c_CdGrupoProd.Value, ;
            "cursor_4c_BuscaGrp", "Grupos", "", par_nKeyCode = 115)

        IF EMPTY(loc_oP1.txt_4c_CdGrupoProd.Value)
            loc_oP1.txt_4c_CdSubgrupo.Value = ""
            loc_oP1.txt_4c_DsSubgrupo.Value = ""
            loc_oP1.txt_4c_CdSubgrupo.Refresh
            loc_oP1.txt_4c_DsSubgrupo.Refresh
        ENDIF

        IF THIS.this_lComFiltro AND USED("CrGrupo") AND USED("CrSubGrupo")
            IF EMPTY(loc_oP1.txt_4c_CdGrupoProd.Value)
                UPDATE CrGrupo SET nMarcas = 1
                UPDATE CrSubGrupo SET nMarcas = 1
            ELSE
                UPDATE CrGrupo SET nMarcas = 0
                UPDATE CrGrupo SET nMarcas = 1 WHERE Grupos = loc_oP1.txt_4c_CdGrupoProd.Value
                UPDATE CrSubGrupo SET nMarcas = 0
                UPDATE CrSubGrupo SET nMarcas = 1 WHERE Grupos = loc_oP1.txt_4c_CdGrupoProd.Value
            ENDIF
        ENDIF
    ENDPROC

    PROCEDURE ValidarSubgrupo
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1, loc_cFiltro
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        loc_cFiltro = "CGrus = " + EscaparSQL(PADR(loc_oP1.txt_4c_CdGrupoProd.Value, 3))
        THIS.AbrirLookup(loc_oP1.txt_4c_CdSubgrupo, loc_oP1.txt_4c_DsSubgrupo, ;
            "SigCdPsg", "Codigos", "Descricaos", "Codigos", loc_oP1.txt_4c_CdSubgrupo.Value, ;
            "cursor_4c_BuscaPsg", "Sub-Grupos", loc_cFiltro, par_nKeyCode = 115)

        IF THIS.this_lComFiltro AND USED("CrSubGrupo")
            IF EMPTY(loc_oP1.txt_4c_CdSubgrupo.Value)
                UPDATE CrSubGrupo SET nMarcas = 1
            ELSE
                UPDATE CrSubGrupo SET nMarcas = 0
                UPDATE CrSubGrupo SET nMarcas = 1 WHERE Grupos = PADR(loc_oP1.txt_4c_CdGrupoProd.Value, 3)
            ENDIF
        ENDIF
    ENDPROC

    PROCEDURE ValidarVendedor
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1, loc_cGrupo
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF USED("CrSigCdPam")
            loc_cGrupo = CrSigCdPam.GrPadVens
        ELSE
            loc_cGrupo = ""
        ENDIF
        IF !EMPTY(loc_oP1.txt_4c_ContaVen.Value)
            IF !fAcessoContas(gc_4c_UsuarioLogado, loc_cGrupo, "C", loc_oP1.txt_4c_ContaVen.Value, ;
                    loc_oP1.txt_4c_ContaVen, loc_oP1.txt_4c_DContaVen)
                =MsgAviso("Acesso Negado !!!")
                loc_oP1.txt_4c_ContaVen.Value = ""
                loc_oP1.txt_4c_ContaVen.Refresh
                loc_oP1.txt_4c_DContaVen.Value = ""
                loc_oP1.txt_4c_DContaVen.Refresh
            ENDIF
        ELSE
            loc_oP1.txt_4c_DContaVen.Value = ""
            loc_oP1.txt_4c_DContaVen.Refresh
        ENDIF
    ENDPROC

