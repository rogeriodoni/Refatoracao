    * HANDLERS LOSTFOCUS - VALIDACOES (PUBLIC obrigatorio para BINDEVENT)
    *==========================================================================
    PROCEDURE ValidarEmpresa
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        THIS.AbrirLookup(loc_oP1.txt_4c_CdEmpresa, loc_oP1.txt_4c_DsEmpresa, ;
            "SigCdEmp", "Cemps", "Razas", "Cemps", loc_oP1.txt_4c_CdEmpresa.Value, ;
            "cursor_4c_BuscaEmp", "Sele" + CHR(231) + CHR(227) + "o de Empresa", "", ;
            par_nKeyCode = 115)
    ENDPROC

    PROCEDURE ValidarGrpEstoque
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF !EMPTY(loc_oP1.txt_4c_CdGrpEstoque.Value)
            =fAcessoContab(gc_4c_UsuarioLogado, "C", loc_oP1.txt_4c_CdGrpEstoque.Value, ;
                loc_oP1.txt_4c_CdGrpEstoque, loc_oP1.txt_4c_DsGrpEstoque)
        ELSE
            loc_oP1.txt_4c_DsGrpEstoque.Value = ""
            loc_oP1.txt_4c_DsGrpEstoque.Refresh
        ENDIF
    ENDPROC

    PROCEDURE ValidarEstoque
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1, loc_cGrupo
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        loc_cGrupo = loc_oP1.txt_4c_CdGrpEstoque.Value
        IF !EMPTY(loc_oP1.txt_4c_CdEstoque.Value)
            IF !fAcessoContas(gc_4c_UsuarioLogado, loc_cGrupo, "C", loc_oP1.txt_4c_CdEstoque.Value, ;
                    loc_oP1.txt_4c_CdEstoque, loc_oP1.txt_4c_DsEstoque)
                =MsgAviso("Acesso Negado !!")
                loc_oP1.txt_4c_CdEstoque.Value = ""
                loc_oP1.txt_4c_CdEstoque.Refresh
                loc_oP1.txt_4c_DsEstoque.Value = ""
                loc_oP1.txt_4c_DsEstoque.Refresh
            ENDIF
        ELSE
            loc_oP1.txt_4c_DsEstoque.Value = ""
            loc_oP1.txt_4c_DsEstoque.Refresh
        ENDIF
    ENDPROC

    PROCEDURE ValidarFornecedor
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        IF !EMPTY(loc_oP1.txt_4c_CFornecedor.Value)
            IF !fAcessoContas(gc_4c_UsuarioLogado, [], "C", loc_oP1.txt_4c_CFornecedor.Value, ;
                    loc_oP1.txt_4c_CFornecedor, loc_oP1.txt_4c_DFornecedor)
                =MsgAviso("Acesso Negado...")
                loc_oP1.txt_4c_CFornecedor.Value = ""
                loc_oP1.txt_4c_DFornecedor.Value = ""
            ENDIF
        ELSE
            loc_oP1.txt_4c_CFornecedor.Value = ""
            loc_oP1.txt_4c_DFornecedor.Value = ""
        ENDIF
        loc_oP1.txt_4c_CFornecedor.Refresh
        loc_oP1.txt_4c_DFornecedor.Refresh
    ENDPROC

    PROCEDURE ValidarLinha
        LPARAMETERS par_nKeyCode, par_nShiftAltCtrl
        IF par_nKeyCode != 13 AND par_nKeyCode != 9 AND par_nKeyCode != 115
            RETURN
        ENDIF
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1
        THIS.AbrirLookup(loc_oP1.txt_4c_Linha, loc_oP1.txt_4c_DLinha, ;
            "SigCdLin", "Linhas", "Descs", "Linhas", loc_oP1.txt_4c_Linha.Value, ;
            "cursor_4c_BuscaLin", "Linhas", "", par_nKeyCode = 115)
        IF THIS.this_lComFiltro AND USED("CrLinha")
            IF EMPTY(loc_oP1.txt_4c_Linha.Value)
                UPDATE CrLinha SET nMarcas = 1
            ELSE
                UPDATE CrLinha SET nMarcas = 0
                UPDATE CrLinha SET nMarcas = 1 WHERE cCodigos = loc_oP1.txt_4c_Linha.Value
            ENDIF
        ENDIF
    ENDPROC

