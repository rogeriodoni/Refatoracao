*==============================================================================
* FORMSIGREPES.PRG
* FASE A: Layout Visual - Relatorio de Posicao de Estoque
* Tipo: REPORT (herda FormBase, BO herda RelatorioBase)
* Migrado de: sigrepes.SCX (frmrelatorio)
*==============================================================================

DEFINE CLASS Formsigrepes AS FormBase

    *-- Dimensoes e aparencia (EXATAS do original)
    Height      = 604
    Width       = 1000
    DataSession = 2
    ShowWindow  = 1
    WindowType  = 1
    AutoCenter  = .T.
    BorderStyle = 2
    ControlBox  = .F.
    MaxButton   = .F.
    MinButton   = .F.
    TitleBar    = 0
    Themes      = .F.
    ShowTips    = .T.

    *-- Propriedades customizadas
    this_cMensagemErro = ""
    this_lComFiltro    = .F.
    this_cCodImg       = ""
    this_cPcatalogo    = ""
    this_cTipoVal      = ""
    this_cTipoRel      = ""
    this_lFiltroAtivo  = .F.

    *==========================================================================
    * INICIALIZARFORM - Cria todos os controles visuais
    *==========================================================================
    PROCEDURE InicializarForm
        LOCAL loc_lSucesso, loc_cEtapa
        loc_lSucesso = .T.
        loc_cEtapa = "inicio"
        TRY
            loc_cEtapa = "Caption"
            THIS.Caption = "Relat" + CHR(243) + "rio de Posi" + CHR(231) + CHR(227) + "o de Estoque"

            loc_cEtapa = "Picture/fundo"
            IF TYPE("gc_4c_CaminhoIcones") = "U"
                gc_4c_CaminhoIcones = ""
            ENDIF
            THIS.Picture = gc_4c_CaminhoIcones + "fundo_cad_1003.jpg"

            loc_cEtapa = "CREATEOBJECT(SigrepesBO)"
            THIS.this_oBusinessObject = CREATEOBJECT("SigrepesBO")

            loc_cEtapa = "CriarCursoresPlaceholder"
            THIS.CriarCursoresPlaceholder()

            loc_cEtapa = "ConfigurarCabecalho"
            THIS.ConfigurarCabecalho()
            THIS.cnt_4c_Cabecalho.lbl_4c_Titulo.Caption = THIS.Caption

            loc_cEtapa = "ConfigurarBotoes"
            THIS.ConfigurarBotoes()

            loc_cEtapa = "ConfigurarBotoesExtras"
            THIS.ConfigurarBotoesExtras()

            loc_cEtapa = "ConfigurarPageFrame"
            THIS.ConfigurarPageFrame()

            loc_cEtapa = "ConfigurarEventos"
            THIS.ConfigurarEventos()

            loc_cEtapa = "CarregarCursoresReferencia"
            THIS.CarregarCursoresReferencia()

            loc_cEtapa = "InicializarCampos"
            THIS.InicializarCampos()

            loc_cEtapa = "AplicarControleAcesso"
            THIS.AplicarControleAcesso()

            loc_cEtapa = "MCursor"
            LOCAL loc_lMCursor
            loc_lMCursor = THIS.MCursor()
            loc_lMCursor = IIF(TYPE("loc_lMCursor") = "L", loc_lMCursor, .T.)
            IF !(loc_lMCursor)
                loc_lSucesso = .F.
            ENDIF

            loc_cEtapa = "SetFocus Produto"
            IF loc_lSucesso
                THIS.pgf_4c_Paginas.Page1.txt_4c_Produto.SetFocus
                THIS.pgf_4c_Paginas.Page1.Refresh
            ENDIF

        CATCH TO loc_oErro
            THIS.this_cMensagemErro = loc_oErro.Message
            MsgErro("Erro em InicializarForm (Formsigrepes)" + CHR(13) + ;
                "Etapa: " + loc_cEtapa + CHR(13) + ;
                "Mensagem: " + loc_oErro.Message + CHR(13) + ;
                "Linha: " + TRANSFORM(loc_oErro.LineNo) + CHR(13) + ;
                "Procedure: " + loc_oErro.Procedure, "Erro Detalhado InicializarForm")
            loc_lSucesso = .F.
        ENDTRY
        RETURN loc_lSucesso
    ENDPROC

    *==========================================================================
    * ATUALIZARESTADOCONTROLES - Override: formulario de relatorio nao usa CRUD
    *==========================================================================
    PROCEDURE AtualizarEstadoControles
        RETURN
    ENDPROC

    *==========================================================================
    * CARREGARCURSORESREFERENCIA - Carrega cursores auxiliares via SQL Server
    *==========================================================================
    PROTECTED PROCEDURE CarregarCursoresReferencia
        LOCAL loc_cQuery

        *-- Verificar conexao disponivel (modo teste sem banco)
        IF TYPE("gnConnHandle") = "U" OR gnConnHandle <= 0
            RETURN .T.
        ENDIF

        *-- CrSigCdEmp - Empresas
        loc_cQuery = [Select CEmps,Razas,Cidas,RazSocs,Endes,Cidas,IEs,CGCs,Ativas,RegTribs ] + ;
                     [From SigCdEmp Order By CEmps ]
        IF SQLEXEC(gnConnHandle, loc_cQuery, "CrSigCdEmp") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (CrSigCdEmp)")
            RETURN .F.
        ENDIF
        SELECT CrSigCdEmp
        INDEX ON CEmps TAG CEmps
        GO TOP

        *-- CrSigCdPam - Parametros
        IF SQLEXEC(gnConnHandle, [Select GrPadVens, MoedEtqs, Moedaps From SigCdPam ], "CrSigCdPam") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (CrSigCdPam)")
            RETURN .F.
        ENDIF

        *-- CrSigCdPac - Parametros Contabeis
        IF SQLEXEC(gnConnHandle, [Select * From SigCdPac ], "CrSigCdPac") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (CrSigCdPac)")
            RETURN .F.
        ENDIF

        *-- CrSigCdMoe - Moedas
        IF SQLEXEC(gnConnHandle, [Select * From SigCdMoe ], "CrSigCdMoe") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (CrSigCdMoe)")
            RETURN .F.
        ENDIF
        SELECT CrSigCdMoe
        INDEX ON CMoes TAG CMoes
        GO TOP

        *-- CrSigCdCot - Cotacoes
        IF SQLEXEC(gnConnHandle, [Select * From SigCdCot ], "CrSigCdCot") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (CrSigCdCot)")
            RETURN .F.
        ENDIF
        SELECT CrSigCdCot
        INDEX ON CMoes + DTOS(Datas) TAG CMoeData
        GO TOP

        *-- TmpMoe - Moedas com cotacao
        IF SQLEXEC(gnConnHandle, [Select CMoes,DMoes From SigCdMoe Where Cotas = 1 ], "TmpMoe") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (TmpMoe)")
            RETURN .F.
        ENDIF
        SELECT TmpMoe
        INDEX ON CMoes TAG CMoes
        INDEX ON DMoes TAG DMoes
        GO TOP

        *-- CrSigCdUni - Unidades (para inicializar pmedio)
        IF SQLEXEC(gnConnHandle, [Select cUnis, cestos From SigCdUni ], "CrSigCdUni") < 1
            RETURN .F.
        ENDIF
        SELECT CrSigCdUni
        INDEX ON cUnis TAG cUnis
        LOCATE FOR cestos = "3"
        IF EOF()
            THIS.pgf_4c_Paginas.Page1.obj_4c_Pmedio.Value = 1
        ELSE
            THIS.pgf_4c_Paginas.Page1.obj_4c_Pmedio.Value = 2
        ENDIF
        GO TOP

        *-- CrSigCdOpe - Operacoes de Estoque
        loc_cQuery = [Select a.Dopes From SigCdOpe a inner join SigOpCdc b on b.Dopes = a.Dopes ] + ;
                     [Where a.Estoqs = 2 and b.OpeInatvs <> 1 Order By a.Dopes ]
        IF SQLEXEC(gnConnHandle, loc_cQuery, "CrSigCdOpe") < 1
            MsgErro("Falha na Conex" + CHR(227) + "o (CrSigCdOpe)")
            RETURN .F.
        ENDIF
        SELECT CrSigCdOpe
        INDEX ON Dopes TAG Dopes
        GO TOP

        RETURN .T.
    ENDPROC

    *==========================================================================
    * INICIALIZARCAMPOS - Inicializa valores padrao dos campos do formulario
    *==========================================================================
    PROTECTED PROCEDURE InicializarCampos
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1

        WITH loc_oP1
            .txt_4c_CdEmpresa.Value    = ""
            .txt_4c_DsEmpresa.Value    = ""
            .txt_4c_DsGrpEstoque.Value = ""
            .txt_4c_CdGrpEstoque.Value = ""
            .txt_4c_CdEstoque.Value    = ""
            .txt_4c_DsEstoque.Value    = ""
            .txt_4c_ContaVen.Value     = " "
            .txt_4c_DContaVen.Value    = " "
            .txt_4c_CdGrupoProd.Value  = ""
            .txt_4c_DsGrupoProd.Value  = ""
            .txt_4c_CdSubgrupo.Value   = ""
            .txt_4c_DsSubgrupo.Value   = ""
            .txt_4c_Linha.Value        = ""
            .txt_4c_DLinha.Value       = ""
            .txt_4c_Fip.Value          = ""
            .txt_4c_DFip.Value         = ""
            .obj_4c_OptRfEstoque.Value = 1
            .txt_4c_DataSaldo.Value    = {}
            .txt_4c_DataSaldo.Enabled  = .F.
            .Refresh
        ENDWITH
    ENDPROC

    *==========================================================================
    * APLICARCONTROLEACESSO - fChecaAcesso para visibilidade/habilitacao
    *==========================================================================
    PROTECTED PROCEDURE AplicarControleAcesso
        LOCAL loc_oP1
        loc_oP1 = THIS.pgf_4c_Paginas.Page1

        *-- Checkboxes de custo/preco
        loc_oP1.chk_4c_Custo.Enabled    = fChecaAcesso("SIGREPES", "CUSTO")
        loc_oP1.chk_4c_PreCusto.Enabled  = loc_oP1.chk_4c_Custo.Enabled
        loc_oP1.chk_4c_CMedio.Enabled    = fChecaAcesso("SIGREPES", "MEDIO")
        loc_oP1.chk_4c_CMedioF.Enabled   = loc_oP1.chk_4c_CMedio.Enabled
        loc_oP1.chk_4c_Venda.Enabled     = fChecaAcesso("SIGREPES", "VENDA")
        loc_oP1.chk_4c_Ideal.Enabled     = loc_oP1.chk_4c_Venda.Enabled

        *-- Posicao de estoque (componente)
        loc_oP1.obj_4c_OptPosEstoq.Enabled = fChecaAcesso("SIGREPES", "COMPONENTE")
        loc_oP1.obj_4c_OptPosEstoq.Visible = fChecaAcesso("SIGREPES", "COMPONENTE")

        *-- Filtro por operacao de movimento (controle form-level, nao Page1)
        THIS.txt_4c_Dopes.Enabled = fChecaAcesso("SIGREPES", "FILTRAMOV")
        THIS.txt_4c_Dopes.Visible = fChecaAcesso("SIGREPES", "FILTRAMOV")

        *-- Buscar label da operacao
        IF PEMSTATUS(loc_oP1, "lbl_4c_Dopes", 5)
            loc_oP1.lbl_4c_Dopes.Visible = fChecaAcesso("SIGREPES", "FILTRAMOV")
        ENDIF

        *-- Botoes extras
        THIS.cmd_4c_SPED.Visible       = fChecaAcesso("SIGREPES", "GERASPED")
        THIS.cmd_4c_Cat.Visible         = fChecaAcesso("SIGREPES", "CAT44")
        THIS.cmd_4c_Lancamento.Visible  = fChecaAcesso("SIGREPES", "FINANCEIRO")

        *-- Gera Movimento
        THIS.cmd_4c_GeraMovto.Visible = fChecaAcesso("SIGREPES", "GERAMOV")
        IF PEMSTATUS(THIS, "lbl_4c_Say3", 5)
            THIS.lbl_4c_Say3.Visible      = THIS.cmd_4c_GeraMovto.Visible
        ENDIF
        THIS.txt_4c_Dopes.Visible = THIS.cmd_4c_GeraMovto.Visible

        *-- Filtros multiplos (Page2)
        THIS.this_lComFiltro = .F.
        THIS.pgf_4c_Paginas.Page2.Enabled = .F.
        THIS.pgf_4c_Paginas.Page2.Caption = ""
        IF fChecaAcesso("SIGREPES", "FILTRO")
            THIS.pgf_4c_Paginas.Page2.Enabled = .T.
            THIS.pgf_4c_Paginas.Page2.Caption = "Filtros M" + CHR(250) + "ltiplos"
        ENDIF
    ENDPROC

    *==========================================================================
    * CRIAR CURSORES PLACEHOLDER
    * Todos os grids precisam de cursor criado ANTES da configuracao visual
    *==========================================================================
    PROTECTED PROCEDURE CriarCursoresPlaceholder
        SET NULL ON

        IF USED("cursor_4c_OrigMerc")
            USE IN cursor_4c_OrigMerc
        ENDIF
        CREATE CURSOR cursor_4c_OrigMerc (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1

        IF USED("cursor_4c_TipoInvs")
            USE IN cursor_4c_TipoInvs
        ENDIF
        CREATE CURSOR cursor_4c_TipoInvs (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1

        SET NULL ON
        IF USED("cursor_4c_Grupo")
            USE IN cursor_4c_Grupo
        ENDIF
        CREATE CURSOR cursor_4c_Grupo (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_Subgrupo")
            USE IN cursor_4c_Subgrupo
        ENDIF
        CREATE CURSOR cursor_4c_Subgrupo (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_Linha")
            USE IN cursor_4c_Linha
        ENDIF
        CREATE CURSOR cursor_4c_Linha (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_SitTrib")
            USE IN cursor_4c_SitTrib
        ENDIF
        CREATE CURSOR cursor_4c_SitTrib (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_Cor")
            USE IN cursor_4c_Cor
        ENDIF
        CREATE CURSOR cursor_4c_Cor (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_GrpVenda")
            USE IN cursor_4c_GrpVenda
        ENDIF
        CREATE CURSOR cursor_4c_GrpVenda (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_ClasFis")
            USE IN cursor_4c_ClasFis
        ENDIF
        CREATE CURSOR cursor_4c_ClasFis (nMarcas N(1,0), CDescricaos C(50))
        APPEND BLANK
        REPLACE nMarcas WITH 1
        SET NULL OFF

        SET NULL ON
        IF USED("cursor_4c_RefFor")
            USE IN cursor_4c_RefFor
        ENDIF
        CREATE CURSOR cursor_4c_RefFor (CDescricaos C(50))
        SET NULL OFF
    ENDPROC

    *==========================================================================
    * CONFIGURARCABECALHO - Container escuro + titulo (equivalente a cntSombra)
    * Original: cntSombra.Top=0, Left=-1, Width=1010, Height=80
    *==========================================================================
    PROTECTED PROCEDURE ConfigurarCabecalho
        THIS.AddObject("cnt_4c_Cabecalho", "Container")
        WITH THIS.cnt_4c_Cabecalho
            .Top         = 0
            .Left        = -1
            .Width       = 1010
            .Height      = 80
            .BackColor   = RGB(100, 100, 100)
            .BorderWidth = 0
            .Visible     = .T.
        ENDWITH

        THIS.cnt_4c_Cabecalho.AddObject("lbl_4c_Titulo", "Label")
        WITH THIS.cnt_4c_Cabecalho.lbl_4c_Titulo
            .Top       = 25
            .Left      = 20
            .AutoSize  = .F.
            .Width     = THIS.Width
            .Height    = 30
            .Caption   = "Relat" + CHR(243) + "rio de Posi" + CHR(231) + CHR(227) + "o de Estoque"
            .FontName  = "Tahoma"
            .FontSize  = 14
            .FontBold  = .T.
            .ForeColor = RGB(255, 255, 255)
            .BackStyle = 0
            .Visible   = .T.
        ENDWITH

        THIS.cnt_4c_Cabecalho.lbl_4c_Titulo.Visible = .T.
        THIS.cnt_4c_Cabecalho.Visible = .T.
    ENDPROC

    *==========================================================================
    * CONFIGURARBOTOES - Container de botoes de relatorio
    * Original: btnReport.Top=-2, Left=694, Height=85, Width=310
    * Botoes: Visualiza(5), Imprime(80), DocExcel(155), Sair(230)
    *==========================================================================
    PROTECTED PROCEDURE ConfigurarBotoes
        THIS.AddObject("cmg_4c_Botoes", "CommandGroup")
        WITH THIS.cmg_4c_Botoes
            .Top           = 0
            .Left          = 725
            .Width         = 273
            .Height        = 80
            .ButtonCount   = 4
            .BackStyle     = 0
            .BorderStyle   = 0
            .BorderColor   = RGB(136, 189, 188)
            .SpecialEffect = 1
            .Themes        = .F.
            .Visible       = .T.
        ENDWITH

        *-- Botao Visualizar - Left=5 (base do bloco)
        WITH THIS.cmg_4c_Botoes.Buttons(1)
            .Top             = 3
            .Left            = 5
            .Width          = 65
            .Height          = 70
            .Caption         = "Visualizar"
            .FontName       = "Comic Sans MS"
            .FontBold       = .T.
            .FontItalic     = .T.
            .FontSize        = 8
            .Picture         = gc_4c_CaminhoIcones + "relatorio_video_26.jpg"
            .PicturePosition = 13
            .Themes          = .F.
            .BackColor       = RGB(255, 255, 255)
            .ForeColor       = RGB(90, 90, 90)
            .Visible         = .T.
        ENDWITH

        *-- Botao Imprimir - Left=72 (gap 2 apos Visualizar)
        WITH THIS.cmg_4c_Botoes.Buttons(2)
            .Top             = 3
            .Left            = 72
            .Width          = 65
            .Height          = 70
            .Caption         = "Imprimir"
            .FontName       = "Comic Sans MS"
            .FontBold       = .T.
            .FontItalic     = .T.
            .FontSize        = 8
            .Picture         = gc_4c_CaminhoIcones + "relatorio_impressora_26.jpg"
            .PicturePosition = 13
            .Themes          = .F.
            .BackColor       = RGB(255, 255, 255)
            .ForeColor       = RGB(90, 90, 90)
            .Visible         = .T.
        ENDWITH

        *-- Botao Arquivos Email - Left=139 (gap 2 apos Imprimir)
        WITH THIS.cmg_4c_Botoes.Buttons(3)
            .Top             = 3
            .Left            = 139
            .Width          = 65
            .Height          = 70
            .Caption         = "\<Arquivos Email"
            .WordWrap        = .T.
            .FontName       = "Comic Sans MS"
