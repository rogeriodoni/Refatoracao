    PROTECTED PROCEDURE ConfigurarPage2
        LOCAL loc_oPage, loc_oGrd

        loc_oPage = THIS.pgf_4c_Paginas.Page2

        *-- getReffs: Left=101, Top=0, H=23, W=113 (referencia para filtro)
