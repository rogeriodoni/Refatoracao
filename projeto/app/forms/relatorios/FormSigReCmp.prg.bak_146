                    .FontName  = "Comic Sans MS"
                    .FontSize  = 8
                    .Top       = 4
                    .Left      = 90
                    .Width     = 90
                    .Height    = 17
                    .BackStyle = 0
                    .Visible   = .T.
                ENDWITH
                .Visible = .T.
            ENDWITH

            *-- ===== ROW 2: MOVIMENTACAO / OP =====
