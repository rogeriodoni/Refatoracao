                .Value         = 0
                .InputMask     = "######"
                .FontName      = "Tahoma"
                .FontSize      = 8
                .ForeColor     = RGB(90, 90, 90)
                .BackColor     = RGB(255, 255, 255)
                .Enabled       = .F.
                .SpecialEffect = 0
