                .Value         = 0
                .InputMask     = "######"
                .FontName      = "Tahoma"
                .FontSize      = 8
                .ForeColor     = RGB(90, 90, 90)
                .BackColor     = RGB(255, 255, 255)
                .SpecialEffect = 0
                .Visible       = .T.
            ENDWITH

            loc_oPagina.AddObject("lbl_4c_Lbl_op", "Label")
            WITH loc_oPagina.lbl_4c_Lbl_op
                .Top       = 66
