            ENDWITH

            loc_oPagina.AddObject("lbl_4c_Label3", "Label")
            WITH loc_oPagina.lbl_4c_Label3
                .Top       = 66
                .Left      = 422
                .Width     = 20
                .Height    = 18
                .Caption   = "at" + CHR(233)
                .FontName  = "Tahoma"
