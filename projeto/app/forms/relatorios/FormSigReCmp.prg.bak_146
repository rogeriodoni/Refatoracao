                .Left      = 511
                .Width     = 172
                .Height    = 17
                .Caption   = "Tipo de Movimenta" + CHR(231) + CHR(227) + "o"
                .FontName  = "Tahoma"
                .FontSize  = 8
                .FontBold  = .T.
                .ForeColor = RGB(90, 90, 90)
                .BackStyle = 0
                .Visible   = .T.
            ENDWITH

