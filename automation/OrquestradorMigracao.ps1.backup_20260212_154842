function Invoke-Etapa05_Migracao {
    param([string]$TaskId, [string]$BaseName)

    Write-StepHeader "ETAPA 5" "Executar migracao (Claude CLI)"

    $state = Get-TaskState -TaskId $TaskId -TasksDir $config.paths.tasks
    $tentativas = $state.etapas."05_migracao".tentativas
    $maxTentativas = $config.retry.maxTentativasMigracao

    if ($tentativas -ge $maxTentativas) {
        throw "Numero maximo de tentativas atingido para migracao: $maxTentativas"
    }

    Start-Etapa -TaskId $TaskId -Etapa "05_migracao" -TasksDir $config.paths.tasks

    try {
        $taskPath = Join-Path $config.paths.tasks $TaskId
        $metaPromptFile = Join-Path $taskPath "meta_prompt.md"
        $outputFile = Join-Path $taskPath "migracao_output.txt"
        $logFile = Get-TaskLogPath -TaskId $TaskId -Etapa "05_migracao" -TasksDir $config.paths.tasks

        # Normaliza BaseName para case-insensitive (VFP converte para uppercase)
        # Prefere arquivo _slim.txt se disponivel (para forms grandes)
        $txtFiles = Get-ChildItem -Path $taskPath -Filter "*_form_codigo_fonte.txt" -File | Where-Object { $_.Name -notlike "*_slim*" }
        if ($txtFiles.Count -eq 0) {
            throw "Arquivo *_form_codigo_fonte.txt nao encontrado em $taskPath"
        }

        $txtFile = $txtFiles[0].FullName
        $slimFile = $txtFile -replace "\.txt$", "_slim.txt"

        # Se arquivo slim existe e eh menor que 500KB, usar ele
        if (Test-Path $slimFile) {
            $slimSize = (Get-Item $slimFile).Length / 1024
            if ($slimSize -lt 500) {
                Write-Host "Usando arquivo reduzido: $([System.IO.Path]::GetFileName($slimFile)) ($([math]::Round($slimSize, 2)) KB)" -ForegroundColor Cyan
                $txtFile = $slimFile
            }
        }

        $mapeamentoFile = Join-Path $taskPath "mapeamento.json"

        # Prepara arquivos de contexto (OBRIGATORIOS para o Claude CLI)
        $contextFiles = @(
            $txtFile,                                                           # 1. Codigo fonte (ou versao slim)
            "C:\4c\docs\FORMCOR_LICOES_APRENDIDAS.md",                        # 2. Licoes aprendidas (5 problemas)
            "C:\4c\CLAUDE.md",                                                 # 3. Regras dos 3 PILARES
            "C:\4c\docs\migration_guide.md"                                   # 4. Checklist geral
        )

        # Adiciona mapeamento.json se existir
        if (Test-Path $mapeamentoFile) {
            $contextFiles += $mapeamentoFile
        }

        Write-Host ""
        Write-Host "Arquivos de contexto para Claude CLI:" -ForegroundColor Cyan
        foreach ($file in $contextFiles) {
            if (Test-Path $file) {
                $size = [math]::Round((Get-Item $file).Length / 1KB, 2)
                Write-Host "  [OK] $(Split-Path -Leaf $file) ($size KB)" -ForegroundColor Green
            }
            else {
                Write-Host "  [AVISO] $(Split-Path -Leaf $file) (nao encontrado)" -ForegroundColor Yellow
            }
        }
        Write-Host ""

        # Invoca Claude CLI com contexto completo
        & (Join-Path $config.paths.automation "ClaudeInvoker.ps1") `
            -PromptFile $metaPromptFile `
            -OutputFile $outputFile `
            -Model $config.claude.model `
            -Timeout $config.claude.timeout `
            -LogFile $logFile `
            -ContextFiles $contextFiles

        if ($LASTEXITCODE -ne 0) {
            throw "Claude CLI retornou codigo de erro: $LASTEXITCODE"
        }

        Write-Host "Claude CLI finalizado. Verificando arquivos gerados..." -ForegroundColor Cyan

        # ===================================================================
        # VALIDACAO POS-MIGRACAO: Verificar se arquivos foram gerados
        # ===================================================================
        $formClass = Get-FormClassName -BaseName $BaseName
        $boClass = Get-BOClassName -BaseName $BaseName
        $formFile = Join-Path $config.paths.projeto "app\forms\cadastros\$formClass.prg"
        $boFile = Join-Path $config.paths.projeto "app\classes\$boClass.prg"

        $formExists = Test-Path $formFile
        $boExists = Test-Path $boFile

        if (-not $formExists -or -not $boExists) {
            Write-Host ""
            Write-Host "========================================================" -ForegroundColor Yellow
            Write-Host "ARQUIVOS NAO GERADOS NA PRIMEIRA TENTATIVA" -ForegroundColor Yellow
            Write-Host "========================================================" -ForegroundColor Yellow
            Write-Host "  Form: $formFile - $(if($formExists){'OK'}else{'PENDENTE'})" -ForegroundColor $(if($formExists){'Green'}else{'Yellow'})
            Write-Host "  BO:   $boFile - $(if($boExists){'OK'}else{'PENDENTE'})" -ForegroundColor $(if($boExists){'Green'}else{'Yellow'})
            Write-Host ""

            # Verifica se o output indica formulario complexo
            $outputContent = ""
            if (Test-Path $outputFile) {
                $outputContent = Get-Content -Path $outputFile -Raw -ErrorAction SilentlyContinue
            }

            # ===================================================================
            # RETRY AUTOMATICO COM PROMPT FORCADO PARA FORMULARIOS COMPLEXOS
            # Todos os formularios DEVEM ser migrados, independente da complexidade
            # ===================================================================
            Write-Host "Iniciando RETRY AUTOMATICO com instrucoes forcadas..." -ForegroundColor Cyan
            Write-Host ""

            # Cria prompt forcado que EXIGE geracao de codigo
            $forcePromptFile = Join-Path $taskPath "force_prompt.md"
            $forcePromptContent = @"
# INSTRUCAO OBRIGATORIA - GERAR CODIGO AGORA

**ATENCAO**: Na tentativa anterior, voce identificou este formulario como "complexo" e pediu orientacao.
**ISSO NAO E ACEITAVEL**. TODOS os formularios devem ser migrados, independente da complexidade.

## REGRA ABSOLUTA
Voce DEVE gerar os arquivos de codigo AGORA:
1. **$boClass.prg** em C:\4c\projeto\app\classes\
2. **$formClass.prg** em C:\4c\projeto\app\forms\cadastros\

## ESTRATEGIA PARA FORMULARIOS COMPLEXOS

Se o formulario NAO segue o padrao FormBase simples (CRUD de uma tabela), use esta estrategia:

### 1. Business Object Customizado
- NAO herde de BusinessBase se nao fizer sentido
- Crie classe propria com metodos especificos para a funcionalidade
- Implemente TODA a logica de negocio necessaria

### 2. Form Customizado
- Pode herdar de FormBase OU criar classe propria
- Para PageFrames aninhados: crie todos os niveis necessarios
- Para drag-and-drop: implemente os eventos MouseDown/MouseUp/MouseMove
- Para multiplas tabelas: crie cursores separados para cada uma
- Para grids com checkboxes: use colunas com controles customizados

### 3. Funcionalidades Especiais
- Multiplas conexoes SQL: use variaveis locais (loc_nConn1, loc_nConn2)
- Cursores temporarios: crie no Init e destrua no Destroy
- Copiar dados entre registros: implemente metodos especificos

## OUTPUT ESPERADO

Voce DEVE usar a ferramenta Write para criar os arquivos:
- Write para criar $boClass.prg
- Write para criar $formClass.prg

NAO pergunte, NAO peca confirmacao, NAO liste opcoes.
GERE O CODIGO COMPLETO E FUNCIONAL AGORA.

---

$(Get-Content $metaPromptFile -Raw)
"@

            Set-Content -Path $forcePromptFile -Value $forcePromptContent -Encoding UTF8

            Write-Host "Prompt forcado criado: $forcePromptFile" -ForegroundColor Cyan
            Write-Host "Executando Claude CLI com instrucoes forcadas..." -ForegroundColor Cyan

            # Executa novamente com prompt forcado
            $forceOutputFile = Join-Path $taskPath "migracao_output_force.txt"

            & (Join-Path $config.paths.automation "ClaudeInvoker.ps1") `
                -PromptFile $forcePromptFile `
                -OutputFile $forceOutputFile `
                -Model $config.claude.model `
                -Timeout ($config.claude.timeout * 2) `
                -LogFile (Join-Path $taskPath "logs\05_migracao_force.log") `
                -ContextFiles $contextFiles

            # Verifica novamente se arquivos foram gerados
            $formExists = Test-Path $formFile
            $boExists = Test-Path $boFile

            if (-not $formExists -or -not $boExists) {
                # Ainda nao gerou - tentar uma terceira vez com modelo mais poderoso
                Write-Host ""
                Write-Host "Arquivos ainda nao gerados. Tentando com modelo OPUS..." -ForegroundColor Yellow

                & (Join-Path $config.paths.automation "ClaudeInvoker.ps1") `
                    -PromptFile $forcePromptFile `
                    -OutputFile (Join-Path $taskPath "migracao_output_opus.txt") `
                    -Model "opus" `
                    -Timeout ($config.claude.timeout * 3) `
                    -LogFile (Join-Path $taskPath "logs\05_migracao_opus.log") `
                    -ContextFiles $contextFiles

                # Verifica mais uma vez
                $formExists = Test-Path $formFile
                $boExists = Test-Path $boFile
            }

            if (-not $formExists -or -not $boExists) {
                throw "Apos multiplas tentativas, os arquivos Form/BO nao foram gerados. Verifique os logs em $taskPath\logs\"
            }
        }

        Write-Host ""
        Write-Host "Migracao executada com sucesso" -ForegroundColor Green
        Write-Host "  Form: $formFile" -ForegroundColor Green
        Write-Host "  BO:   $boFile" -ForegroundColor Green

        Complete-Etapa -TaskId $TaskId -Etapa "05_migracao" -TasksDir $config.paths.tasks -Metadata @{
            outputFile = $outputFile
            formFile = $formFile
            boFile = $boFile
            formExists = $formExists
            boExists = $boExists
        }
    }
    catch {
        $erroMsg = $_.Exception.Message
        Fail-Etapa -TaskId $TaskId -Etapa "05_migracao" -ErroMsg $erroMsg -TasksDir $config.paths.tasks
        throw
    }
}

